local function refreshCharacterParts(force)
    local now = tick()
    if not force and (now - lastCharacterPartsRefresh) < CHARACTER_PARTS_REFRESH_INTERVAL then
        return
    end
    lastCharacterPartsRefresh = now
    cachedCharacterParts = {}
    local char = player.Character
    if not char then return end
    for _, inst in ipairs(char:GetDescendants()) do
        if inst:IsA("BasePart") then
            cachedCharacterParts[#cachedCharacterParts + 1] = inst
        end
    end
end

local function toggleNoclip(state)
    if state then
        if not noclipConnection then
            refreshCharacterParts(true)
            noclipConnection = RunService.Stepped:Connect(function()
                refreshCharacterParts(false)
                for i = 1, #cachedCharacterParts do
                    local part = cachedCharacterParts[i]
                    if part and part.Parent then
                        part.CanCollide = false
                    else
                        -- Обновим кэш на следующем тике, если часть пропала.
                        lastCharacterPartsRefresh = 0
                        break
                    end
                end
            end)
        end
    else
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
    end
end

local function makeObjectsTransparent()
    if areObjectsTransparent then return end
    areObjectsTransparent = true
    transparentObjects = {}

    -- Важно: не сканируем весь Workspace (это даёт фризы).
    -- Меняем только ближайшие части вокруг игрока.
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local overlap = OverlapParams.new()
    overlap.FilterType = Enum.RaycastFilterType.Exclude
    overlap.FilterDescendantsInstances = {char}
    local nearbyParts = Workspace:GetPartBoundsInRadius(hrp.Position, 300, overlap)  -- Увеличил с 220 до 300

    for i = 1, #nearbyParts do
        local obj = nearbyParts[i]
        if obj and obj:IsA("BasePart") and obj.CanCollide then
            transparentObjects[obj] = {coll = obj.CanCollide, trans = obj.Transparency}
            obj.CanCollide = false
            -- Пол/земля/стены делаем прозрачными
            local n = obj.Name:lower()
            if n:find("floor") or n:find("ground") or n:find("land") or n:find("wall") or n:find("ceiling") then
                obj.Transparency = 0.7  -- Увеличил прозрачность с 0.6 до 0.7
            end
        end
    end

    print("Global noclip & partial transparency enabled (radius: 300)")
end

local function restoreObjectsTransparency()
    if not areObjectsTransparent then return end
    areObjectsTransparent = false

    for part, data in pairs(transparentObjects) do
        if part and part.Parent then
            part.CanCollide = data.coll
            part.Transparency = data.trans
        end
    end

    transparentObjects = {}
    print("Objects collision restored")
end

local flyConnection = nil
local isFlying = false
local flyDirection = nil -- "down" or "up"
local hideStartTime = 0 -- Время когда начали прятаться
local MIN_DEPTH_Y = -70 -- Минимальная глубина до -70
local justReturnedFromUnderground = false -- Флаг что только что вернулся на поверхность
local RETURN_COOLDOWN = 3 -- Кулдаун в секундах после возврата на поверхль
local transparentObjects = {} -- Для хранения прозрачных объектов
local areObjectsTransparent = false -- Флаг прозрачности

local function startFlyDown(depthY)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        isFlying = true
        flyDirection = "down"
        hrp.Anchored = false 

        -- ЧАСТИ ТЕЛА БОЛЬШЕ НЕ СКРЫВАЕМ (Transparency = 1 удалено)
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end

        flyConnection = RunService.Heartbeat:Connect(function()
            if isFlying and hrp and hrp.Parent then
                if flyDirection == "down" then
                    if hrp.Position.Y <= depthY then
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        hrp.Anchored = true
                        hrp.CFrame = CFrame.new(hrp.Position.X, depthY, hrp.Position.Z)
                        isFlying = false
                        flyDirection = nil
                        if flyConnection then flyConnection:Disconnect() end
                        flyConnection = nil
                        
                        task.spawn(function()
                            while isHidingUnderground and _G.BBN_Running do
                                if hrp and hrp.Parent then
                                    hrp.Anchored = true
                                    hrp.Velocity = Vector3.new(0, -5, 0)
                                    if math.abs(hrp.Position.Y - depthY) > 1 then
                                        hrp.CFrame = CFrame.new(hrp.Position.X, depthY, hrp.Position.Z)
                                    end
                                end
                                task.wait(0.1)
                            end
                        end)
                    else
                        hrp.Velocity = Vector3.new(0, -120, 0)
                        hrp.CFrame = hrp.CFrame * CFrame.new(0, -2.5, 0)
                    end
                end
            end
        end)
    end
end

local function startFlyUp(targetY)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        isFlying = true
        flyDirection = "up"
        hrp.Anchored = false -- Размораживаем для полета

        -- Отключаем коллизию чтобы пролетать сквозь объекты
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end

        -- Создаем флай вверх
        flyConnection = RunService.Heartbeat:Connect(function()
            if isFlying and hrp and hrp.Parent then
                if flyDirection == "up" then
                    -- Проверяем достиг ли нужной высоты
                    if hrp.Position.Y >= targetY then
                        -- Достигли высоты - останавливаемся и ЗАМОРАЖИВАЕМ
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        hrp.Anchored = true
                        
                        -- Постоянно фиксируем в одной точке чтобы не телепортировало обратно
                        hrp.CFrame = CFrame.new(hrp.Position.X, targetY, hrp.Position.Z)
                        
                        isFlying = false
                        flyDirection = nil
                        if flyConnection then flyConnection:Disconnect() end
                        flyConnection = nil
                        print("Reached height. Frozen in air at Y: " .. hrp.Position.Y)
                        
                        -- Дополнительный цикл фиксации пока мы спрятаны (НЕПРЕРЫВНО)
                        task.spawn(function()
                            while isHidingUnderground and _G.BBN_Running do
                                if hrp and hrp.Parent then
                                    hrp.Anchored = true
                                    hrp.Velocity = Vector3.new(0, 0, 0)
                                    -- Принудительно держим наверху
                                    if hrp.Position.Y < targetY - 2 then
                                        hrp.CFrame = CFrame.new(hrp.Position.X, targetY, hrp.Position.Z)
                                    end
                                end
                                task.wait(0.1) -- Частота фиксации выше
                            end
                        end)
                    else
                        hrp.Velocity = Vector3.new(0, 60, 0)
                        hrp.CFrame = hrp.CFrame * CFrame.new(0, 1, 0) -- Принудительное смещение для надежности
                    end
                end
            end
        end)

        print("Fly up started to Y: " .. targetY)
    end
end

