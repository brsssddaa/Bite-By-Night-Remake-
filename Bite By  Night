local function nuclearCleanup()
    local wasRunning = _G.BBN_Running
    _G.BBN_Running = false
    _G.BBN_Status = "Off"
    allEspEnabled, autoGenEnabled, autoCursorEnabled, spiritEnabled = false, false, false, false
    states["ESP ALL"] = false
    espLiveToken = espLiveToken + 1
    local offTok = espLiveToken
    cancelEspLoopThread()

    if spiritConn then spiritConn:Disconnect() spiritConn = nil end
    if inputConnection then inputConnection:Disconnect() inputConnection = nil end
    if noclipConnection then noclipConnection:Disconnect() noclipConnection = nil end
    if flyConnection then flyConnection:Disconnect() flyConnection = nil end

    -- Останавливаем флай и сбрасываем состояние персонажа только если он был активен
    isFlying = false
    isHidingUnderground = false
    flyDirection = nil
    
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp and wasRunning then
        hrp.Anchored = false
        hrp.Velocity = Vector3.new(0, 0, 0)
    end
    
    -- Восстанавливаем коллизию и прозрачность только если мы их меняли
    if wasRunning then
        restoreObjectsTransparency()
        toggleNoclip(false)
        
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
    end
    
    for _, v in ipairs(CoreGui:GetChildren()) do
        if v.Name == "BiteByNightMenu" or v.Name == "BBN_Loading" or v.Name == "BBN_AutoWinLogs" then
            v:Destroy()
        end
    end
    
    clearEsp()
    local function espPurgeNuclear()
        if offTok ~= espLiveToken then return end
        clearEsp()
    end
    task.defer(espPurgeNuclear)

    local wipe = {}
    local allw = Workspace:GetDescendants()
    for i = 1, #allw do
        local obj = allw[i]
        if string.find(obj.Name, "BBN_", 1, true) then
            wipe[#wipe + 1] = obj
        end
        if i % 4000 == 0 then task.wait() end
    end
    destroyInstanceList(wipe)
end
