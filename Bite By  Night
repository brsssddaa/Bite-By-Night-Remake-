local function getKillerDist()
    local now = tick()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return 1000 end

    -- Используем кэшированный объект если он валиден (обновляем раз в 2 секунды)
    if cachedKillerObj and cachedKillerObj.Parent and (now - lastKillerUpdate < 2.0) then
        local khrp = cachedKillerObj:FindFirstChild("HumanoidRootPart") or cachedKillerObj:FindFirstChildWhichIsA("BasePart", true)
        if khrp then
            local d = (hrp.Position - khrp.Position).Magnitude
            lastKillerDist = d
            return d
        end
    end

    local killerObj = nil
    
    -- 1. Check Workspace.PLAYERS
    local playersFolder = Workspace:FindFirstChild("PLAYERS")
    local killerFolder = playersFolder and (playersFolder:FindFirstChild("KILLER") or playersFolder:FindFirstChild("Killer"))
    if killerFolder then
        killerObj = killerFolder:FindFirstChildWhichIsA("Model")
    end
    
    -- 2. Check all players for Role attribute or Name pattern
    if not killerObj then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character and (p:GetAttribute("Role") == "Killer" or p.Name:lower():find("killer")) then
                killerObj = p.Character
                break
            end
        end
    end
    
    -- 3. Check for any Humanoid in Workspace with "Killer" in name (fallback)
    if not killerObj then
        for _, v in ipairs(Workspace:GetChildren()) do
            if v:IsA("Model") and v:FindFirstChild("Humanoid") and (v.Name:lower():find("killer") or v:GetAttribute("Role") == "Killer") then
                killerObj = v
                break
            end
        end
    end

    if killerObj then
        cachedKillerObj = killerObj
        lastKillerUpdate = now
        local killerHRP = killerObj:FindFirstChild("HumanoidRootPart") or killerObj:FindFirstChildWhichIsA("BasePart", true)
        if killerHRP then
            local dist = (hrp.Position - killerHRP.Position).Magnitude
            lastKillerDist = dist
            return dist
        end
    end
    
    lastKillerDist = 1000
    return 1000
end
