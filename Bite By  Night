local function isFuseBoxUsed(fb)
    if not fb then return true end
    -- Проверка по атрибуту (самая быстрая)
    if fb:GetAttribute("Used") or fb:GetAttribute("Filled") or fb:GetAttribute("Active") then return true end
    
    -- Проверка по списку
    for _, usedFb in ipairs(filledFuseBoxes) do
        if usedFb == fb then return true end
    end
    
    -- Быстрая проверка
    local prompt = fb:FindFirstChild("ProximityPrompt") or fb:FindFirstChildWhichIsA("ProximityPrompt", true)
    -- Если промпт есть и включен - Fusebox СВОБОДЕН
    if prompt and prompt.Enabled then return false end
    
    -- Если промпта нет или он выключен - проверяем UI
    local ui = fb:FindFirstChild("BillboardGui") or fb:FindFirstChildWhichIsA("BillboardGui", true)
    if ui then
        local txt = ui:FindFirstChildWhichIsA("TextLabel", true) or ui:FindFirstChild("Label", true)
        if txt then
            local s = txt.Text:lower()
            -- Если видим проценты меньше 100 - значит свободен
            if s:find("%%") then
                local val = tonumber(s:match("(%d+)"))
                if val and val < 99 then return false end
            end
            if s:find("100") or s:find("done") or s:find("full") or s:find("finish") or s:find("заряжен") then return true end
        end
    end
    
    -- Если есть промпт, но он выключен - значит использован
    if prompt and not prompt.Enabled then return true end
    
    -- В сомнительных случаях (нет ни промпта, ни UI) считаем свободным, 
    -- чтобы бот хотя бы попробовал подойти, если объект был найден как FuseBox
    return false
end

local function markFuseBoxUsed(fb)
    if fb and not isFuseBoxUsed(fb) then
        table.insert(filledFuseBoxes, fb)
        print("FuseBox marked as used.")
    end
end
