local usedPizzeriaExits = {} -- Список использованных выходов на Pizzeria

local function buildPizzeriaExitHopQueue()
    pizzeriaHopQueue = {}
    for i = 1, #pizzeriaExits do
        pizzeriaHopQueue[i] = pizzeriaExits[i]
    end
    for i = #pizzeriaHopQueue, 2, -1 do
        local j = math.random(i)
        pizzeriaHopQueue[i], pizzeriaHopQueue[j] = pizzeriaHopQueue[j], pizzeriaHopQueue[i]
    end
    pizzeriaHopIdx = 1
end

local function nextPizzeriaExitPosition()
    if pizzeriaHopIdx == 0 or pizzeriaHopIdx > #pizzeriaHopQueue then
        buildPizzeriaExitHopQueue()
    end
    -- Выбираем случайный неиспользованный выход
    local available = {}
    for i, pos in ipairs(pizzeriaExits) do
        if not usedPizzeriaExits[i] then
            table.insert(available, i)
        end
    end
    
    if #available > 0 then
        local index = available[math.random(1, #available)]
        usedPizzeriaExits[index] = true
        return pizzeriaExits[index]
    else
        -- Если все использованы, берем первый (fallback)
        return pizzeriaExits[1]
    end
end

local function nextForestExitPosition()
    -- Выбираем случайный неиспользованный выход
    local available = {}
    for i, pos in ipairs(forestExits) do
        if not usedForestExits[i] then
            table.insert(available, i)
        end
    end

    if #available > 0 then
        local index = available[math.random(1, #available)]
        usedForestExits[index] = true
        return forestExits[index], index  -- Возвращаем позицию И индекс
    else
        -- Если все использованы, сбрасываем и берем случайный
        usedForestExits = {}
        local index = math.random(1, #forestExits)
        usedForestExits[index] = true
        return forestExits[index], index  -- Возвращаем позицию И индекс
    end
end
