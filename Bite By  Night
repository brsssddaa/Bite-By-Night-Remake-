local function detectMap()
    local gameFolder = Workspace:FindFirstChild("GAME")
    local mapValue = gameFolder and gameFolder:FindFirstChild("CURRENTMAP")
    if mapValue and mapValue.Value ~= "" then
        local name = tostring(mapValue.Value):upper()
        if name:find("FOREST") then return "Forest" end
        if name:find("WAREHOUSE") then return "Warehouse" end
        if name:find("PIZZERIA") or name:find("PIZZA") then return "Pizzeria" end
    end
    local ignore = Workspace:FindFirstChild("IGNORE")
    if ignore then
        for _, obj in ipairs(ignore:GetChildren()) do
            local name = obj.Name:upper()
            if name:find("FOREST") then return "Forest" end
            if name:find("WAREHOUSE") then return "Warehouse" end
            if name:find("PIZZERIA") or name:find("PIZZA") then return "Pizzeria" end
        end
    end
    return "Waiting..."
end

local function isGeneratorFinished(gen)
    if not gen or not gen.Parent then return true end
    
    -- 1. Проверка атрибутов (наиболее надежно)
    local progress = gen:GetAttribute("Progress") or gen:GetAttribute("progress")
    if progress and tonumber(progress) then
        if tonumber(progress) >= 99.9 then return true end
        -- Если прогресс > 0, значит генератор в процессе, НЕ считаем его починенным
        if tonumber(progress) > 0.1 then return false end
    end
    
    if gen:GetAttribute("Finished") == true or gen:GetAttribute("Done") == true or gen:GetAttribute("Completed") == true then return true end
    
    -- 2. Проверка ProximityPrompt
    local prompt = gen:FindFirstChildWhichIsA("ProximityPrompt", true)
    -- Если промпт есть и включен - генератор точно НЕ починен
    if prompt and prompt.Enabled then return false end
    -- Если промпта нет или он выключен - это признак завершения (но не 100%, может быть забаган)
    
    -- 3. Проверка визуальных меток (BillboardGui)
    local ui = gen:FindFirstChildWhichIsA("BillboardGui", true)
    local txt = ui and ui:FindFirstChildWhichIsA("TextLabel", true)
    if txt then
        local s = txt.Text:lower()
        if s:find("100") or s:find("done") or s:find("finish") or s:find("complete") or s:find("заведен") then return true end
        if s:find("%%") then
            local val = tonumber(s:match("(%d+)"))
            if val and val >= 99 then return true end
            if val and val > 0 then return false end
        end
    end
    
    -- 4. Если промпта нет, но есть BillboardGui который не показывает 100% - считаем не готовым
    if not prompt and ui then return false end

    return false
end

local function applyReliableEsp(object, color, labelText, liveToken)
    if liveToken ~= espLiveToken then return end
    if not object or not _G.BBN_Running or not allEspEnabled then return end

    -- Очистка старых тегов с ДРУГИМ текстом (решает проблему дублирования у Minion)
    for _, child in ipairs(object:GetChildren()) do
        if child.Name == "BBN_Tag" and child:IsA("BillboardGui") then
            local lbl = child:FindFirstChild("Label")
            -- Удаляем только если текст не совпадает
            if lbl and lbl.Text ~= labelText then
                child:Destroy()
            end
        end
    end

    local highlight = object:FindFirstChild("BBN_Highlight")
    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = "BBN_Highlight"
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.4
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = object
        table.insert(espHighlights, highlight)
    end
    if liveToken ~= espLiveToken then return end

    if highlight.FillColor ~= color then
        highlight.FillColor = color
    end

    local mainPart = object:IsA("BasePart") and object or object:FindFirstChild("HumanoidRootPart") or object:FindFirstChildWhichIsA("BasePart", true)
    if mainPart then
        local bill = object:FindFirstChild("BBN_Tag")
        if not bill then
            bill = Instance.new("BillboardGui")
            bill.Name = "BBN_Tag"
            bill.Size = UDim2.new(0, 80, 0, 30)
            bill.AlwaysOnTop = true
            bill.StudsOffset = Vector3.new(0, 4, 0)

            local lbl = Instance.new("TextLabel", bill)
            lbl.Name = "Label"
            lbl.Size = UDim2.new(1, 0, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.Font = Enum.Font.FredokaOne
            lbl.TextSize = 10
            lbl.TextStrokeTransparency = 0.5

            bill.Parent = object
            table.insert(espHighlights, bill)
        end
        if liveToken ~= espLiveToken then return end
        bill.Adornee = mainPart
        local lbl = bill:FindFirstChild("Label")
        if lbl and (lbl.Text ~= labelText or lbl.TextColor3 ~= color) then
            lbl.Text = labelText
            lbl.TextColor3 = color
        end
    end
end

-- Кэш объектов для ESP
local cachedObjects = {lastUpdate = 0, isScanning = false, scanStartedAt = 0, data = {generators = {}, killers = {}, survivors = {}, batteries = {}, fuseboxes = {}, escapePoints = {}, minions = {}}}

local function findObjects()
    if cachedObjects.isScanning then
        if tick() - (cachedObjects.scanStartedAt or 0) > 15 then
            warn("[BBN] findObjects: сброс залипшего isScanning")
            cachedObjects.isScanning = false
        else
            return cachedObjects.data
        end
    end
    -- На тяжёлых картах полный сбор объектов очень дорогой: повышаем интервал и сканируем только нужные ветки.
    local foThrottle = (_G.BBN_BatteryCarrying == true) and 6.0 or 3.0
    if tick() - cachedObjects.lastUpdate < foThrottle then
        return cachedObjects.data
    end

    cachedObjects.scanStartedAt = tick()
    cachedObjects.isScanning = true
    local results = {generators = {}, killers = {}, survivors = {}, batteries = {}, fuseboxes = {}, escapePoints = {}, minions = {}}
    local isCarryingBatteryNow = (_G.BBN_BatteryCarrying == true)
    local success, err = pcall(function()
        local scanned = 0
        local function maybeYield()
            scanned = scanned + 1
            if scanned % 900 == 0 then
                task.wait()
            end
        end

        local function scanNode(obj)
            maybeYield()
            if not obj then return end
            local upperName = obj.Name:upper()

            if (upperName:find("GENERATOR") or upperName == "GEN" or upperName:find("STATION") or upperName:find("COMPUTER")) and (obj:IsA("Model") or obj:IsA("BasePart")) then
                local hasBillboard = obj:FindFirstChildWhichIsA("BillboardGui", true)
                local hasPrompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
                local hasProgress = obj:GetAttribute("Progress") ~= nil
                if hasBillboard or hasPrompt or hasProgress then
                    table.insert(results.generators, obj)
                end
            elseif upperName:find("FUSEBOX") and (obj:IsA("Model") or obj:IsA("BasePart")) then
                table.insert(results.fuseboxes, obj)
            elseif upperName:find("MINION") and (obj:IsA("Model") or obj:IsA("BasePart")) then
                table.insert(results.minions, obj)
            elseif (upperName:find("ESCAPE") or upperName:find("EXIT") or upperName:find("ESCAPEPOINT")) and (obj:IsA("Model") or obj:IsA("BasePart")) then
                table.insert(results.escapePoints, obj)
            end
        end

        -- 1) Игроки и роли: без глобального прохода
        local playersFolder = Workspace:FindFirstChild("PLAYERS") or Workspace:FindFirstChild("Players")
        local alive = playersFolder and (playersFolder:FindFirstChild("ALIVE") or playersFolder:FindFirstChild("Alive"))
        local killer = playersFolder and (playersFolder:FindFirstChild("KILLER") or playersFolder:FindFirstChild("Killer"))
        if killer then
            for _, m in ipairs(killer:GetChildren()) do
                if m:IsA("Model") and m:FindFirstChild("Humanoid") then
                    table.insert(results.killers, m)
                end
            end
        end
        if alive then
            for _, m in ipairs(alive:GetChildren()) do
                if m:IsA("Model") and m.Name ~= player.Name then
                    table.insert(results.survivors, m)
                end
            end
        end

        -- 2) Батареи:
        -- Когда батарея уже в руках, не делаем дорогой глубинный обход IGNORE.
        -- Это основной источник фризов во время батарейной фазы.
        local ignoreFolder = Workspace:FindFirstChild("IGNORE") or Workspace:FindFirstChild("Ignore")
        local mapsFolder = Workspace:FindFirstChild("Maps") or Workspace:FindFirstChild("MAPS")
        local mapRoot = mapsFolder and (mapsFolder:FindFirstChild("GAME MAP") or mapsFolder:FindFirstChild("Game Map"))
        local batteryFolder = mapRoot and (mapRoot:FindFirstChild("Batteries") or mapRoot:FindFirstChild("BATTERIES"))

        local seenBattery = {}
        local function pushBatteryRoot(obj)
            if not obj then return end
            local root = obj
            local cursor = obj.Parent
            -- Поднимаемся до папки-контейнера или Workspace
            while cursor and cursor ~= ignoreFolder and cursor ~= batteryFolder and cursor ~= Workspace do
                local cn = cursor.Name:upper()
                if cn:find("BATTERY") or cn == "BAT" then
                    root = cursor
                end
                cursor = cursor.Parent
            end
            if not seenBattery[root] then
                seenBattery[root] = true
                table.insert(results.batteries, root)
            end
        end

        -- Сбор из папки Batteries на карте (если есть)
        if batteryFolder then
            for _, obj in ipairs(batteryFolder:GetChildren()) do
                pushBatteryRoot(obj)
            end
        end

        -- Сбор из IGNORE
        if ignoreFolder then
            if isCarryingBatteryNow then
                -- Дешёвый режим: достаточно верхнего уровня IGNORE.
                for _, obj in ipairs(ignoreFolder:GetChildren()) do
                    local un = obj.Name:upper()
                    if (un:find("BATTERY") or un == "BAT") and (obj:IsA("Model") or obj:IsA("BasePart") or obj:IsA("Tool")) then
                        pushBatteryRoot(obj)
                    end
                end
            else
                -- Полный режим: собираем ВСЕ батареи из IGNORE.
                for _, obj in ipairs(ignoreFolder:GetDescendants()) do
                    if not _G.BBN_Running then break end
                    local un = obj.Name:upper()
                    if (un:find("BATTERY") or un == "BAT") and (obj:IsA("Model") or obj:IsA("BasePart") or obj:IsA("Tool")) then
                        pushBatteryRoot(obj)
                    end
                end
            end
        end

        -- Fallback: поиск "Battery" в корне карты и в папке Batteries
        if mapRoot and not isCarryingBatteryNow then
            -- Сначала проверяем саму папку Batteries (если она не была обработана)
            if batteryFolder then
                for _, obj in ipairs(batteryFolder:GetDescendants()) do
                    local un = obj.Name:upper()
                    if un:find("BATTERY") or un == "BAT" then
                        pushBatteryRoot(obj)
                    end
                end
            end
            -- Затем детей корня карты
            for _, obj in ipairs(mapRoot:GetChildren()) do
                local un = obj.Name:upper()
                if un:find("BATTERY") or un == "BAT" then
                    pushBatteryRoot(obj)
                end
            end
        end

        -- 3) Карта: сканируем несколько известных корней карты (а не только "GAME MAP")
        local scannedRoots = {}
        local function scanRootDesc(root)
            if not root or scannedRoots[root] then return end
            scannedRoots[root] = true
            for _, obj in ipairs(root:GetDescendants()) do
                if not _G.BBN_Running then break end
                scanNode(obj)
            end
        end

        local mapsFolder = Workspace:FindFirstChild("Maps") or Workspace:FindFirstChild("MAPS")
        local gameFolder = Workspace:FindFirstChild("GAME") or Workspace:FindFirstChild("Game")
        local mapRoot = mapsFolder and (mapsFolder:FindFirstChild("GAME MAP") or mapsFolder:FindFirstChild("Game Map"))

        -- ВСЕГДА сканируем корень карты и GAME папку, так как там FuseBoxes и таймеры
        scanRootDesc(mapRoot)
        scanRootDesc(gameFolder)

        if not isCarryingBatteryNow then
            if mapsFolder then
                for _, m in ipairs(mapsFolder:GetChildren()) do
                    if m:IsA("Folder") or m:IsA("Model") then
                        scanRootDesc(m)
                    end
                end
            end
            scanRootDesc(ignoreFolder)
        else
            -- В carry-фазе пропускаем только тяжелый IGNORE и дополнительные папки карт
            -- Киллеры уже собраны выше из PLAYERS.
        end
        local minionFolder = Workspace:FindFirstChild("Minion")
        if not minionFolder and ignoreFolder then
            minionFolder = ignoreFolder:FindFirstChild("Minion")
        end
        if minionFolder then
            local seenMinion = {}
            for _, m in ipairs(minionFolder:GetDescendants()) do
                if m:IsA("Model") or m:IsA("BasePart") then
                    local root = m
                    local p = m.Parent
                    while p and p ~= minionFolder and p ~= Workspace do
                        root = p
                        p = p.Parent
                    end
                    if not seenMinion[root] then
                        seenMinion[root] = true
                        table.insert(results.minions, root)
                    end
                end
            end
        end

        -- Резерв: если генераторы не найдены и мы НЕ несем батарею
        if #results.generators == 0 and not isCarryingBatteryNow then
            for _, top in ipairs(Workspace:GetChildren()) do
                if not _G.BBN_Running then break end
                local n = top.Name:upper()
                if top ~= playersFolder and (top:IsA("Folder") or top:IsA("Model")) and (n:find("MAP") or n:find("GAME") or n:find("IGNORE") or n:find("ENV")) then
                    scanRootDesc(top)
                end
            end
        end
    end)

    if success then
        cachedObjects.data = results
        cachedObjects.lastUpdate = tick()
    else
        warn("[BBN] findObjects failed: " .. tostring(err))
    end
    cachedObjects.isScanning = false
    return cachedObjects.data
end

local function destroyInstanceList(list)
    for i = #list, 1, -1 do
        local inst = list[i]
        if inst then
            pcall(function() inst:Destroy() end)
        end
    end
end

-- Полная чистка ESP без лагов: только Workspace (не весь game), сбор в таблицу + редкие task.wait при обходе
local function clearEsp()
    for _, obj in pairs(espHighlights) do
        if obj then
            pcall(function() obj:Destroy() end)
        end
    end
    espHighlights = {}
    local wipe = {}
    local desc = Workspace:GetDescendants()
    for i = 1, #desc do
        local inst = desc[i]
        local n = inst.Name
        if n == "BBN_Highlight" or n == "BBN_Tag" then
            wipe[#wipe + 1] = inst
        end
        if i % 3000 == 0 then
            task.wait()
        end
    end
    destroyInstanceList(wipe)
    local ch = player.Character
    if ch and not ch:IsDescendantOf(Workspace) then
        for _, inst in ipairs(ch:GetDescendants()) do
            local n = inst.Name
            if n == "BBN_Highlight" or n == "BBN_Tag" then
                pcall(function() inst:Destroy() end)
            end
        end
    end
end

local function espPurgeIfStillOff(offToken)
    if allEspEnabled or offToken ~= espLiveToken then return end
    clearEsp()
end

-- Минимум отложенных полных проходов (без 5–6 вызовов подряд — они давали фризы)
local function scheduleEspOffPurges(offSessionToken)
    task.defer(function() espPurgeIfStillOff(offSessionToken) end)
    task.delay(0.45, function() espPurgeIfStillOff(offSessionToken) end)
end

local function cancelEspLoopThread()
    local t = espLoopThread
    espLoopThread = nil
    if t then
        pcall(task.cancel, t)
    end
end

local function toggleAllEsp(enable)
    if not enable then
        allEspEnabled = false
        states["ESP ALL"] = false
        cancelEspLoopThread()
        espLiveToken = espLiveToken + 1
        local offSession = espLiveToken
        clearEsp()
        scheduleEspOffPurges(offSession)
        return
    end

    espLiveToken = espLiveToken + 1
    local sessionLive = espLiveToken
    allEspEnabled = true
    states["ESP ALL"] = true
    cancelEspLoopThread()

    local th
    th = task.spawn(function()
        local ok, err = pcall(function()
            while allEspEnabled and _G.BBN_Running and sessionLive == espLiveToken do
                local found = findObjects()
                if not allEspEnabled or sessionLive ~= espLiveToken then
                    clearEsp()
                    break
                end

                for _, k in ipairs(found.killers) do
                    if not allEspEnabled or sessionLive ~= espLiveToken then break end
                    if k.Name ~= player.Name then
                        applyReliableEsp(k, Color3.fromRGB(255, 50, 50), "KILLER", sessionLive)
                    end
                end

                for _, s in ipairs(found.survivors) do
                    if not allEspEnabled or sessionLive ~= espLiveToken then break end
                    applyReliableEsp(s, Color3.fromRGB(50, 255, 50), s.Name, sessionLive)
                end

                for _, g in ipairs(found.generators) do
                    if not allEspEnabled or sessionLive ~= espLiveToken then break end
                    local finished = isGeneratorFinished(g)
                    local color = finished and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
                    applyReliableEsp(g, color, finished and "DONE" or "IDLE", sessionLive)
                end

                for _, b in ipairs(found.batteries) do
                    if not allEspEnabled or sessionLive ~= espLiveToken then break end
                    applyReliableEsp(b, Color3.fromRGB(0, 150, 255), "BATTERY", sessionLive)
                end

                for _, m in ipairs(found.minions or {}) do
                    if not allEspEnabled or sessionLive ~= espLiveToken then break end
                    applyReliableEsp(m, Color3.fromRGB(255, 120, 0), "MINION", sessionLive)
                end

                task.wait(0.5)
            end
        end)
        if not ok and err then
            warn("[BBN] ESP loop: " .. tostring(err))
        end
        if espLoopThread == th then
            espLoopThread = nil
        end
        if sessionLive ~= espLiveToken then
            return
        end
        if not allEspEnabled or not _G.BBN_Running then
            clearEsp()
        end
    end)
    espLoopThread = th
end

local function getFurthestUnfinishedGenerator()
    local found = findObjects()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position
    local furthest = nil
    local maxDist = -1
    for _, gen in ipairs(found.generators) do
        if not isGeneratorFinished(gen) then
            local genPart = gen:IsA("BasePart") and gen or gen:FindFirstChildWhichIsA("BasePart", true)
            if genPart then
                local dist = (myPos - genPart.Position).Magnitude
                if dist > maxDist then
                    maxDist = dist
                    furthest = gen
                end
            end
        end
    end
    return furthest
end

local function hasBattery()
    local now = tick()
    if _G.BBN_BatteryCacheTime and (now - _G.BBN_BatteryCacheTime) < 0.25 then
        return _G.BBN_BatteryCacheValue == true
    end
    
    local char = player.Character
    local backpack = player:FindFirstChild("Backpack")
    
    local batteryResult = false
    
    local function check(obj)
        if not obj then return false end
        local name = obj.Name:upper()
        return name:find("BATTERY") or name == "BAT"
    end

    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if check(item) then
                batteryResult = true
                break
            end
        end
    end
    
    if not batteryResult and char then
        -- Проверяем инструменты в руках
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") and check(item) then
                batteryResult = true
                break
            end
            -- Проверяем если батарея просто прикреплена к персонажу (не как Tool)
            if (item:IsA("Model") or item:IsA("BasePart")) and check(item) then
                batteryResult = true
                break
            end
        end
    end
    
    _G.BBN_BatteryCacheValue = batteryResult
    _G.BBN_BatteryCacheTime = now
    return batteryResult
end

local function anyoneElseHasBattery()
    local playersFolder = Workspace:FindFirstChild("PLAYERS")
    local alive = playersFolder and playersFolder:FindFirstChild("ALIVE")
    if alive then
        for _, other in ipairs(alive:GetChildren()) do
            if other:IsA("Model") and other.Name ~= player.Name then
                if other:FindFirstChild("Battery") then
                    return true
                end
            end
        end
    end
    return false
end

local function isHeldByOther(obj)
    if not obj or not obj.Parent then return false end
    
    -- Проверка на нахождение в IGNORE - если там, то НЕ занято другими игроками
    local fullPath = obj:GetFullName()
    if fullPath:find("IGNORE") or fullPath:find("Ignore") then
        return false
    end
    
    -- 1. Проверка: находится ли объект внутри персонажа другого игрока
    local current = obj.Parent
    while current and current ~= Workspace do
        if current:IsA("Model") then
            -- Если есть Humanoid и это не я
            if current:FindFirstChildWhichIsA("Humanoid") then
                return current.Name ~= player.Name
            end
            -- Если родитель - папка ALIVE или PLAYERS, и имя модели не моё
            local pName = current.Parent and current.Parent.Name:upper() or ""
            if (pName == "ALIVE" or pName == "PLAYERS" or pName == "KILLER") and current.Name ~= player.Name then
                return true
            end
        elseif current:IsA("Tool") then
            -- Если объект внутри Tool, проверяем кто держит этот Tool
            local char = current.Parent
            if char and char:IsA("Model") and char:FindFirstChildWhichIsA("Humanoid") then
                return char.Name ~= player.Name
            end
            return true -- Если в тулзе, но персонаж не найден - скорее всего кем-то поднят
        end
        current = current.Parent
    end
    
    -- 2. Проверка атрибутов (в некоторых играх ставится атрибут при подборе)
    if obj:GetAttribute("Held") or obj:GetAttribute("Owner") or obj:GetAttribute("Picked") then
        local owner = obj:GetAttribute("Owner")
        if owner and tostring(owner) ~= player.Name then return true end
        return not owner -- Если Held=true но Owner нет - считаем занятым
    end

    return false
end

local currentTween = nil
local lastAimTime = 0
local function smoothAim(targetPos, duration)
    local cam = Workspace.CurrentCamera
    local targetCF = CFrame.new(cam.CFrame.Position, targetPos)
    
    if currentTween then currentTween:Cancel() end
    
    -- Сохраняем старый тип камеры и ставим Scriptable
    if cam.CameraType ~= Enum.CameraType.Scriptable then
        cam.CameraType = Enum.CameraType.Scriptable
    end
    
    local myAimTime = tick()
    lastAimTime = myAimTime
    
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    currentTween = TweenService:Create(cam, tweenInfo, {CFrame = targetCF})
    currentTween:Play()
    
    -- После завершения твина возвращаем Custom тип, но только если не было нового вызова
    task.spawn(function()
        currentTween.Completed:Wait()
        if lastAimTime == myAimTime and cam.CameraType == Enum.CameraType.Scriptable then
            cam.CameraType = Enum.CameraType.Custom
        end
    end)
    
    return currentTween
end

local function isMinionOnMe(foundMinions, char, hrp)
    if not char or not hrp then return false end
    local head = char:FindFirstChild("Head")
    local leftFoot = char:FindFirstChild("LeftFoot") or char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftLowerLeg")
    local rightFoot = char:FindFirstChild("RightFoot") or char:FindFirstChild("Right Leg") or char:FindFirstChild("RightLowerLeg")
    for _, d in ipairs(char:GetDescendants()) do
        local dn = d.Name and d.Name:upper() or ""
        if dn:find("MINION") then
            return true
        end
    end
    for _, m in ipairs(foundMinions or {}) do
        local mp = m:IsA("BasePart") and m or m:FindFirstChildWhichIsA("BasePart", true)
        if mp then
            if (mp.Position - hrp.Position).Magnitude <= 3.6 then return true end
            if head and (mp.Position - head.Position).Magnitude <= 3.2 then return true end
            if leftFoot and (mp.Position - leftFoot.Position).Magnitude <= 3.4 then return true end
            if rightFoot and (mp.Position - rightFoot.Position).Magnitude <= 3.4 then return true end
            local legsPoint = hrp.Position - Vector3.new(0, 2.6, 0)
            if (mp.Position - legsPoint).Magnitude <= 3.5 then return true end
        end
    end
    return false
end

local function shakeCameraRapid(seconds, stillNeededFn)
    local cam = Workspace.CurrentCamera
    if not cam then return end
    local oldType = cam.CameraType
    cam.CameraType = Enum.CameraType.Scriptable
    local t0 = tick()
    while tick() - t0 < (seconds or 0.8) and _G.BBN_Running do
        if stillNeededFn and not stillNeededFn() then
            break
        end
        local sign = ((math.floor((tick() - t0) * 24) % 2) == 0) and 1 or -1
        local yaw = math.rad(18 * sign)
        local side = 0.18 * sign
        -- Быстрое раскачивание только влево/вправо
        cam.CFrame = cam.CFrame * CFrame.Angles(0, yaw, 0) * CFrame.new(side, 0, 0)
        task.wait(0.035)
    end
    if cam and cam.Parent then
        cam.CameraType = oldType == Enum.CameraType.Scriptable and Enum.CameraType.Custom or oldType
    end
end

local _batteryFallbackCache = {time = 0, list = {}}
local function getBatteryFallbackList()
    local now = tick()
    if now - (_batteryFallbackCache.time or 0) < 5.0 then
        return _batteryFallbackCache.list or {}
    end

    local out = {}
    local ignoreFolder = Workspace:FindFirstChild("IGNORE") or Workspace:FindFirstChild("Ignore")
    if ignoreFolder then
        local seen = {}
        -- Сначала быстрый проход только по детям IGNORE (дешево)
        for _, obj in ipairs(ignoreFolder:GetChildren()) do
            local un = obj.Name and obj.Name:upper() or ""
            if (un:find("BATTERY") or un == "BAT") and (obj:IsA("Model") or obj:IsA("BasePart") or obj:IsA("Tool")) then
                seen[obj] = true
                out[#out + 1] = obj
            end
        end

        -- Если детей с батареями не нашли — редкий глубокий проход
        if #out == 0 then
            for _, obj in ipairs(ignoreFolder:GetDescendants()) do
                local un = obj.Name and obj.Name:upper() or ""
                if (un:find("BATTERY") or un == "BAT") and (obj:IsA("Model") or obj:IsA("BasePart") or obj:IsA("Tool")) then
                    local root = obj
                    local p = obj.Parent
                    while p and p ~= ignoreFolder and p ~= Workspace do
                        local pn = p.Name and p.Name:upper() or ""
                        if pn:find("BATTERY") or pn == "BAT" then
                            root = p
                        end
                        p = p.Parent
                    end
                    if not seen[root] then
                        seen[root] = true
                        out[#out + 1] = root
                    end
                end
            end
        end
    end
    _batteryFallbackCache.time = now
    _batteryFallbackCache.list = out
    return out
end

