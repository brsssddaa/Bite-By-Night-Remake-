local function forceReturnFromHide(currentMap)
    if currentMap == "Forest" then
        ascendToSurface()
    else
        returnToSurface()
    end

    -- Fallback: если исходная позиция потерялась и обычный возврат не выполнился.
    if isHidingUnderground or isFlying then
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            isHidingUnderground = false
            isFlying = false
            stopFly()
            restoreObjectsTransparency()
            toggleNoclip(false)
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end

            local targetY = (hrp.Position.Y < 0) and math.max(4, hrp.Position.Y + 55) or (hrp.Position.Y + 8)
            hrp.Anchored = true
            hrp.CFrame = CFrame.new(hrp.Position.X, targetY, hrp.Position.Z)
            task.wait(0.2)
            hrp.Anchored = false
            hrp.Velocity = Vector3.new(0, 0, 0)

            originalPosBeforeHide = nil
            justReturnedFromUnderground = true
            task.spawn(function()
                task.wait(RETURN_COOLDOWN)
                justReturnedFromUnderground = false
            end)
        end
    end
end

