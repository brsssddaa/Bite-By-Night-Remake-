                            markTeleport()
                            lastSafeZoneTeleportAt = tick()
                        end
                    end
                    task.wait(1)
                    continue
                end

                -- ПРОВЕРКА ВРЕМЕНИ (6 AM)
                local totalMins = getGameTime()
                if totalMins >= 360 and totalMins < 1000 then
                    if not isEscaping then
                        print("It's 6 AM! Prioritizing escape.")
                        isEscaping = true
                        -- Сброс всех состояний скрытия для побега
                        isHidingUnderground = false
                        isFlying = false
                        stopFly()
                        if hrp then hrp.Anchored = false end
                        
                        pcall(function() 
                            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
                        end)
                    end
                elseif totalMins < 360 then
                    if isEscaping then
                        print("Time is before 6 AM. Resetting escape state.")
                        isEscaping = false
                    end
                end

                -- === HELPER FUNCTIONS FOR ESCAPE ===
                local function checkEscapeSuccess()
                    local char = player.Character
                    if not char then return false end

                    -- Проверка 1: Роль изменилась на Lobby
                    local parent = char.Parent
                    if parent and parent.Name:upper() == "LOBBY" then
                        return true
                    end

                    -- Проверка 2: Карта изменилась на Waiting...
                    if detectMap() == "Waiting..." then
                        return true
                    end

                    return false
                end

                local function flyToExit(targetPos, map)
                    local char = player.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if not hrp then return false end

                    print("Flying to exit at: " .. tostring(targetPos))

                    -- Включаем прозрачность объектов
                    makeObjectsTransparent()

                    -- Определяем высоту/глубину прятки в зависимости от карты
                    local hideY
                    if map == "Pizzeria" then
                        hideY = MIN_DEPTH_Y  -- Вниз (как при прятках)
                    elseif map == "Forest" then
                        hideY = 100  -- Вверх (как при прятках)
                    else
                        hideY = MIN_DEPTH_Y  -- По умолчанию вниз
                    end

                    -- Шаг 1: Летим по Y до высоты/глубины прятки
                    _G.BBN_Status = "Flying to hide level..."
                    if map == "Forest" then
                        startFlyUp(hideY)
                    else
                        startFlyDown(hideY)
                    end

                    -- Ждем пока достигнем нужной высоты
                    local timeout = tick() + 15
                    while isFlying and tick() < timeout do
                        task.wait(0.1)
                    end

                    if tick() >= timeout then
                        print("Timeout waiting for Y movement")
                        restoreObjectsTransparency()
                        return false
                    end

                    -- Шаг 2: Летим по X и Z к выходу (на той же высоте)
                    _G.BBN_Status = "Flying to exit X/Z..."
                    hrp.Anchored = false

                    local targetXZ = Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z)
                    local startTime = tick()

                    while (hrp.Position - targetXZ).Magnitude > 5 and tick() - startTime < 20 do
                        local direction = (targetXZ - hrp.Position).Unit
                        hrp.Velocity = direction * 50
                        hrp.CFrame = hrp.CFrame + direction * 2
                        task.wait(0.05)

                        -- Проверка успешности побега
                        if checkEscapeSuccess() then
                            print("Escape successful during X/Z movement!")
                            restoreObjectsTransparency()
                            return true
                        end
                    end

                    -- Шаг 3: Летим по Y к выходу (вниз или вверх в зависимости от карты)
                    _G.BBN_Status = "Flying to exit Y..."

                    if map == "Forest" then
                        -- Forest: летим вниз к выходу
                        startFlyDown(targetPos.Y)
                    else
                        -- Pizzeria: летим вверх к выходу
                        startFlyUp(targetPos.Y)
                    end

                    -- Ждем пока достигнем выхода
                    timeout = tick() + 15
                    while isFlying and tick() < timeout do
                        task.wait(0.1)

                        -- Проверка успешности побега
                        if checkEscapeSuccess() then
                            print("Escape successful during final Y movement!")
                            restoreObjectsTransparency()
                            return true
                        end
                    end

                    -- Финальная телепортация к точке выхода
                    hrp.CFrame = CFrame.new(targetPos)
                    task.wait(2)

                    restoreObjectsTransparency()
                    return checkEscapeSuccess()
                end

                -- === FLY TO TARGET (Generators/Batteries) ===
                local function flyToTarget(targetPos, targetName)
                    local char = player.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if not hrp then return false end

                    -- ПРОВЕРКА: Не летим если мы в Safe Zone
                    if inSafeZone then
                        print("❌ Cannot fly from Safe Zone! Use teleport instead.")
                        return false
                    end

                    print("🚀 Flying to " .. targetName .. " at: " .. tostring(targetPos))

                    -- Включаем прозрачность объектов
                    makeObjectsTransparent()

                    -- Определяем карту и высоту (КАК ПРИ ПРЯТКАХ)
                    local map = detectMap()
                    local hideY

                    if map == "Forest" then
                        hideY = 100  -- Вверх для Forest (как при прятках)
                    elseif map == "Warehouse" or map == "Pizzeria" or map == "Minefield" or map == "Gulag" then
                        hideY = MIN_DEPTH_Y  -- Вниз для Warehouse, Pizzeria и других (-70)
                    else
                        hideY = MIN_DEPTH_Y  -- По умолчанию вниз для всех остальных (-70)
                    end

                    print("Map: " .. map .. " | Hide Y: " .. hideY)

                    -- Шаг 1: Летим по Y до высоты прятки
                    _G.BBN_Status = "Flying Y to hide level..."
                    print("Step 1: Flying to Y=" .. hideY)

                    if map == "Forest" then
                        startFlyUp(hideY)
                    else
                        startFlyDown(hideY)
                    end

                    -- Ждем достижения высоты с постоянной проверкой
                    local timeout = tick() + 20  -- Увеличил таймаут для Forest
                    local lastHeightCheck = tick()

                    while isFlying and tick() < timeout do
                        task.wait(0.1)

                        -- Проверка высоты каждые 3 секунды
                        if tick() - lastHeightCheck >= 3 then
                            local currentY = hrp.Position.Y
                            print("⏱️ Height check: Current Y=" .. math.floor(currentY) .. " | Target Y=" .. hideY)
                            lastHeightCheck = tick()
                        end

                        -- Проверка высоты - достигли ли нужной Y?
                        local currentY = hrp.Position.Y
                        local heightReached = false

                        if map == "Forest" then
                            -- Для Forest проверяем что поднялись достаточно высоко
                            if currentY >= hideY - 3 then  -- Уменьшил допуск с 5 до 3 для точности
                                heightReached = true
                            end
                        else
                            -- Для остальных карт проверяем что опустились достаточно низко
                            if currentY <= hideY + 3 then
                                heightReached = true
                            end
                        end

                        if heightReached then
                            print("✅ Height check passed: Y=" .. math.floor(currentY) .. " (target: " .. hideY .. ")")
                            -- Останавливаем полет и фиксируем на нужной высоте
                            stopFlyAndFreeze()
                            hrp.CFrame = CFrame.new(hrp.Position.X, hideY, hrp.Position.Z)
                            hrp.Anchored = true
                            task.wait(0.2)  -- Небольшая пауза для стабилизации
                            break
                        end

                        -- Проверка на маньяка
                        if getKillerDist() < 55 then
                            print("❌ Killer approaching during fly! Aborting.")
                            restoreObjectsTransparency()
                            stopFly()
                            return false
                        end
                    end

                    if tick() >= timeout then
                        print("❌ Timeout waiting for Y movement. Current Y: " .. hrp.Position.Y .. " Target: " .. hideY)
                        restoreObjectsTransparency()
                        stopFly()
                        return false
                    end

                    print("✅ Reached hide level Y=" .. hrp.Position.Y)

                    -- АНТИ-AFK: Фальшивые движения во время полета
                    local function sendFakeMovement()
                        pcall(function()
                            -- Имитируем нажатия клавиш движения
                            local keys = {Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S, Enum.KeyCode.D}
                            local randomKey = keys[math.random(1, #keys)]

                            VirtualInputManager:SendKeyEvent(true, randomKey, false, game)
                            task.wait(0.05)
                            VirtualInputManager:SendKeyEvent(false, randomKey, false, game)
                        end)
                    end

                    -- Шаг 2: Летим по X и Z к цели (ПЛАВНЫЙ ПОЛЕТ + АНТИ-AFK)
                    _G.BBN_Status = "Flying X/Z to " .. targetName .. "..."
                    print("Step 2: Flying X/Z to target")
                    hrp.Anchored = false

                    local targetXZ = Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z)
                    local startTime = tick()
                    local lastFakeMove = tick()
                    local lastHeightCheck = tick()

                    -- Скорость зависит от карты
                    local flySpeed = 60  -- Увеличил базовую скорость с 45 до 60
                    if map == "Forest" then
                        flySpeed = 65  -- Forest еще быстрее
                    elseif map == "Warehouse" then
                        flySpeed = 70  -- Warehouse самый быстрый (против телепорта назад)
                    end

                    local smoothness = 0.85  -- Увеличил плавность с 0.8 до 0.85

                    while (hrp.Position - targetXZ).Magnitude > 5 and tick() - startTime < 25 do
                        local direction = (targetXZ - hrp.Position).Unit

                        -- ПЛАВНОЕ движение через Velocity (без резких CFrame скачков)
                        local currentVel = hrp.Velocity
                        local targetVel = direction * flySpeed
                        hrp.Velocity = currentVel:Lerp(targetVel, smoothness)  -- Плавная интерполяция

                        -- Проверка высоты каждые 3 секунды (особенно важно для Forest)
                        if tick() - lastHeightCheck >= 3 then
                            local currentY = hrp.Position.Y
                            print("⏱️ X/Z Height check: Y=" .. math.floor(currentY) .. " | Should be: " .. hideY)

                            -- Если отклонились от высоты - корректируем
                            if math.abs(currentY - hideY) > 10 then
                                print("⚠️ Height deviation detected! Correcting...")
                                hrp.CFrame = CFrame.new(hrp.Position.X, hideY, hrp.Position.Z)
                                hrp.Anchored = true
                                task.wait(0.1)
                                hrp.Anchored = false
                            end

                            lastHeightCheck = tick()
                        end

                        -- Отправляем фальшивые движения каждые 0.5 сек
                        if tick() - lastFakeMove > 0.5 then
                            sendFakeMovement()
                            lastFakeMove = tick()
                        end

                        task.wait(0.05)

                        -- Проверка на маньяка
                        if getKillerDist() < 55 then
                            print("❌ Killer approaching during X/Z fly! Aborting.")
                            restoreObjectsTransparency()
                            hrp.Anchored = false
                            return false
                        end
                    end

                    print("✅ Reached X/Z position")

                    -- Шаг 3: Летим по Y к цели (НЕМНОГО ВЫШЕ)
                    _G.BBN_Status = "Flying Y to " .. targetName .. "..."
                    print("Step 3: Flying to final Y=" .. (targetPos.Y + 3))

                    local finalY = targetPos.Y + 3  -- На 3 единицы выше цели

                    if map == "Forest" then
                        startFlyDown(finalY)
                    else
                        startFlyUp(finalY)
                    end

                    -- Ждем достижения цели
                    timeout = tick() + 15
                    while isFlying and tick() < timeout do
                        task.wait(0.1)

                        -- Проверка высоты - достигли ли финальной Y?
                        local currentY = hrp.Position.Y
                        if map == "Forest" then
                            -- Для Forest летим вниз к цели
                            if currentY <= finalY + 5 then
                                print("✅ Final height check passed: Y=" .. currentY .. " (target: " .. finalY .. ")")
                                break
                            end
                        else
                            -- Для остальных карт летим вверх к цели
                            if currentY >= finalY - 5 then
                                print("✅ Final height check passed: Y=" .. currentY .. " (target: " .. finalY .. ")")
                                break
                            end
                        end

                        -- Проверка на маньяка
                        if getKillerDist() < 55 then
                            print("❌ Killer approaching during final Y fly! Aborting.")
                            restoreObjectsTransparency()
                            stopFly()
                            return false
                        end
                    end

                    if tick() >= timeout then
                        print("❌ Timeout on final Y. Current: " .. hrp.Position.Y .. " Target: " .. finalY)
                    end

                    -- Финальная позиция (немного выше цели)
                    hrp.CFrame = CFrame.new(targetPos.X, targetPos.Y + 2, targetPos.Z)
                    hrp.Anchored = false  -- Отключаем фиксацию
                    hrp.Velocity = Vector3.new(0, 0, 0)

                    -- Финальное фальшивое движение
                    sendFakeMovement()

                    restoreObjectsTransparency()
                    print("✅ Arrived at " .. targetName .. " at Y=" .. hrp.Position.Y)
                    return true
                end

                -- === ESCAPE SYSTEM (6 AM) ===
                if isEscaping then
                    local currentTotalMins = getGameTime()
                    if currentTotalMins < 360 then
                        print("Forbidden to escape before 6 AM!")
                        isEscaping = false
                        continue
                    end
                    
                    _G.BBN_Status = "Escaping!"
                    
                    -- Проверка не в лобби ли мы уже
                    if currentMap == "Waiting..." or isInLobby then
                        isEscaping = false
                        print("Already in Lobby, stopping escape system.")
                        continue
                    end

                    local map = detectMap()
                    local targetExitPos = nil
                    local exitName = "Exit"
                    local forestExitIndex = nil  -- Для отслеживания какой выход Forest

                    if map == "Pizzeria" then
                        targetExitPos = nextPizzeriaExitPosition()
                        exitName = "Pizzeria Exit"
                    elseif map == "Forest" then
                        targetExitPos, forestExitIndex = nextForestExitPosition()
                        exitName = "Forest Exit #" .. forestExitIndex
                    elseif map == "Warehouse" then
                        targetExitPos = warehouseExitFinalPos
                        exitName = "Warehouse Exit"
                    else
                        -- Динамический поиск для других карт
                        local currentFound = findObjects()
                        if currentFound and currentFound.escapePoints and #currentFound.escapePoints > 0 then
                            local exit = currentFound.escapePoints[math.random(1, #currentFound.escapePoints)]
                            targetExitPos = exit.Position or (exit:IsA("BasePart") and exit.Position)
                            exitName = exit.Name or "Found Exit"
                        else
                            targetExitPos = getExitPos()
                            exitName = "Fallback Exit"
                        end
                    end

                    if targetExitPos then
                        _G.BBN_Status = "Trying Exit..."

                        -- FOREST: Первый выход (индекс 1) - телепорт, второй выход (индекс 2) - Fly
                        if map == "Forest" and forestExitIndex == 2 then
                            print("Forest Exit #2: Using Fly system...")
                            local success = flyToExit(targetExitPos, map)

                            if success then
                                print("Escape successful via Fly!")
                                isEscaping = false
                                continue
                            else
                                print("Fly escape failed, will retry...")
                            end
                        else
                            -- Для всех остальных карт и Forest Exit #1 - телепорт
                            if canTeleport(true, true) then
                                if hrp then
                                    hrp.Anchored = false
                                    pcall(function() VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game) task.wait(0.05) VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game) end)
                                    task.wait(0.1)
                                end

                                print("Teleporting to escape point: " .. exitName)

                                -- СИЛОВОЙ ПОБЕГ: Если мы в нычке, принудительно выходим
                                if isHidingUnderground or isFlying then
                                    print("Forcing escape from hideout!")
                                    hrp.Anchored = true
                                    hrp.Velocity = Vector3.new(0, 0, 0)
                                    restoreObjectsTransparency()
                                    toggleNoclip(false)
                                    hrp.CFrame = CFrame.new(targetExitPos + Vector3.new(0, 5, 0))
                                    task.wait(0.1)
                                    hrp.Anchored = false
                                    markTeleport()
                                else
                                    hrp.CFrame = CFrame.new(targetExitPos + Vector3.new(0, 5, 0))
                                    markTeleport()
                                end

                                task.wait(3) -- Ждем 3 секунды чтобы сработал триггер выхода

                                -- Проверка успешности побега
                                if checkEscapeSuccess() then
                                    print("Escape successful via teleport!")
                                    isEscaping = false
                                    continue
                                end

                                -- Попытка 2: Если телепорт не сработал, используем Fly систему
                                print("Teleport failed, trying Fly system...")

                                -- Для Pizzeria используем Fly систему как fallback
                                if map == "Pizzeria" then
                                    local success = flyToExit(targetExitPos, map)

                                    if success then
                                        print("Escape successful via Fly!")
                                        isEscaping = false
                                        continue
                                    else
                                        print("Fly escape failed, will retry...")
                                    end
                                end
                            end
                        end
                    end

                    task.wait(1)
                    continue
                end

                -- ЗАЩИТА ОТ ТЕЛЕПОРТА В SAFE ZONE ПРИ СТАРТЕ: Ждем пока прогрузятся объекты
                if tick() - cachedObjects.lastUpdate > 2 then
                    found = findObjects()
                else
                    found = cachedObjects.data
                end

                if #found.generators == 0 then
                    _G.BBN_Status = "Waiting for assets..."
                    task.wait(1) 
                    continue
                end

                -- === SYSTEM PROTECTION ===
                -- Return check handled in separate high-frequency thread
                -- (Проверка пряток выше в блоке AUTO FARM — здесь дубликат не нужен)
                if isMinionOnMe(found.minions, char, hrp) then
                    _G.BBN_Status = "Minion on me! Shake"
                    if not isHidingUnderground and not isFlying then
                        goUnderground()
                    end
                    local function minionStillOnMe()
                        local c = player.Character
                        local r = c and c:FindFirstChild("HumanoidRootPart")
                        if not c or not r then return false end
                        local f = cachedObjects.data
                        if tick() - cachedObjects.lastUpdate > 0.6 then
                            f = findObjects()
                        end
                        return isMinionOnMe(f.minions, c, r)
                    end
                    shakeCameraRapid(5, minionStillOnMe)
                    task.wait(0.05)
                    continue
                end

                -- === SEARCH & TELEPORT LOGIC (AUTO FARM ONLY) ===
                -- Кэшируем вызов findObjects на 2.5 секунды для Auto Farm
                if tick() - cachedObjects.lastUpdate > 2.5 then
                    found = findObjects()
                else
                    found = cachedObjects.data
                end
                
                local killerDist = getKillerDist()
                local isCarryingBattery = lastCarryBatteryValue

                -- ПРИОРИТЕТ ЗАЩИТЫ: Если маньяк близко, блокируем ВСЕ действия фермы (кроме побега)
                if killerDist < 60 and not isEscaping then
                    if not isHidingUnderground and not isFlying then
                        _G.BBN_Status = "Waiting for Hide"
                        task.wait(0.1)
                        continue
                    end
                end

                -- If battery heading but battery lost - reset
                if tick() - lastCarryBatteryCheck > (isCarryingBattery and 1.5 or 0.35) then
                    lastCarryBatteryCheck = tick()
                    lastCarryBatteryValue = hasBattery()
                    isCarryingBattery = lastCarryBatteryValue
                end
                if hasBatteryAndHeadingToFuseBox and not isCarryingBattery then
                    hasBatteryAndHeadingToFuseBox = false
                    fuseBoxTargetPosition = nil
                    print("Battery lost! Resetting FuseBox state.")
                end
                
                -- Mini-game check
                local pGui = player:FindFirstChild("PlayerGui")
                local activeMiniEvent = nil
                local currentMiniGameGen = nil
                if pGui then
                    for _, g in ipairs(pGui:GetChildren()) do
                        if g:IsA("ScreenGui") and (g.Name:find("Minigame") or g.Name:find("Generator") or g:FindFirstChild("MainFrame") or g:FindFirstChild("Container")) then
                            local main = g:FindFirstChild("MainFrame") or g:FindFirstChild("Container")
                            if main and (main.Visible or (main:IsA("CanvasGroup") and main.GroupTransparency < 1)) then
                                activeMiniEvent = g:FindFirstChild("Event", true) or main:FindFirstChild("Event", true)
                                local hrpPos = hrp.Position
                                local minDist = 20
                                for _, gen in ipairs(found.generators) do
                                    local genPart = gen:IsA("BasePart") and gen or gen:FindFirstChildWhichIsA("BasePart", true)
                                    if genPart then
                                        local d = (hrpPos - genPart.Position).Magnitude
                                        if d < minDist then
                                            minDist = d
                                            currentMiniGameGen = gen
                                        end
                                    end
                                end
                                if activeMiniEvent then break end
                            end
                        end
                    end
                end

                -- If carrying battery, don't repair generators
                if hasBattery() and activeMiniEvent then
                    print("Carrying battery! Closing generator UI.")
                    pcall(function() VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game) end)
                    activeMiniEvent = nil
                end

                if activeMiniEvent and currentMiniGameGen == currentRepairTargetGen then
                    _G.BBN_Status = "Repairing Gen"
                    lastMiniGameTime = tick()
                    if tick() - lastRepairTime >= repairCooldown then
                        print("Repairing... Cooldown: " .. repairCooldown)
                        activeMiniEvent:FireServer({["Wires"]=true,["Switches"]=true,["Lever"]=true,["Type"]="Finish"}) 
                        lastRepairTime = tick()
                        repairCooldown = math.random(5, 7)
                        
                        task.wait(0.5)
                        if isGeneratorFinished(currentRepairTargetGen) then
                            print("Generator finished! Waiting 5 seconds before next...")
                            _G.BBN_GensRepaired = (_G.BBN_GensRepaired or 0) + 1
                            currentRepairTargetGen = nil
                            _G.BBN_Status = "Gen Finished (Wait)"
                            task.wait(5) -- Ждем 5 секунд после завершения
                        end
                    end
                else
                    -- === PRIORITY LOGIC: BATTERY -> GENERATORS -> SAFE ZONE ===
                    -- 1. Используем тот же `found`, что в начале итерации (findObjects сам кэшируется; отдельный вызов здесь дублировал нагрузку)
                    local unfinishedGens = {}
                    for _, gen in ipairs(found.generators) do
                        if not isGeneratorFinished(gen) and not brokenGenerators[gen] then
                            table.insert(unfinishedGens, gen)
                        end
                    end
                    
                    local nowCarryTick = tick()
                    if nowCarryTick - lastCarryBatteryCheck > (lastCarryBatteryValue and 1.5 or 0.35) then
                        lastCarryBatteryCheck = nowCarryTick
                        lastCarryBatteryValue = hasBattery()
                    end
                    local carryingBattery = lastCarryBatteryValue

                    local battery = nil
                    local nearestBatteryDist = math.huge
                    local availableBatteries = 0
                    if not carryingBattery then
                        local batteryCandidates = {}
                        for _, b in ipairs(found.batteries) do
                            batteryCandidates[#batteryCandidates + 1] = b
                        end

                        -- Fallback: если кэш/структура карты временно не дала батареи, берём напрямую из IGNORE
                        if #batteryCandidates == 0 then
                            local fallbackBat = getBatteryFallbackList()
                            for i = 1, #fallbackBat do
                                batteryCandidates[#batteryCandidates + 1] = fallbackBat[i]
                            end
                        end

                        for _, b in ipairs(batteryCandidates) do
                            if not isHeldByOther(b) then
                                availableBatteries = availableBatteries + 1
                                local bPart = b:IsA("BasePart") and b or b:FindFirstChild("Position") or b:FindFirstChildWhichIsA("BasePart", true)
                                if bPart then
                                    local d = (hrp.Position - bPart.Position).Magnitude
                                    if d < nearestBatteryDist then
                                        nearestBatteryDist = d
                                        battery = b
                                    end
                                end
                            end
                        end
                    end
                    
                    local fbFolder = Workspace:FindFirstChild("Maps") and Workspace.Maps:FindFirstChild("GAME MAP") and Workspace.Maps["GAME MAP"]:FindFirstChild("FuseBoxes")
                    local bestFB = nil
                    local minDist = math.huge
                    local availableFB = 0
                    
                    local function scanFB(fb)
                        if fb:IsA("Model") and not isFuseBoxUsed(fb) then
                            availableFB = availableFB + 1
                            local p = fb:FindFirstChild("Position") or fb:FindFirstChildWhichIsA("BasePart", true)
                            if p then
                                local d = (hrp.Position - p.Position).Magnitude
                                if d < minDist then
                                    minDist = d
                                    bestFB = fb
                                end
                            end
                        end
                    end

                    if fbFolder then
                        for _, fb in ipairs(fbFolder:GetChildren()) do scanFB(fb) end
                    end
                    for _, fb in ipairs(found.fuseboxes) do scanFB(fb) end

                    -- СТРОГИЙ ПРИОРИТЕТ БАТАРЕИ: если есть батарея в руках ИЛИ есть свободная батарея на карте
                    if isCarryingBattery or battery then
                        _G.BBN_Status = string.format("Bat: %d | Gens: %d", availableBatteries, #unfinishedGens)
                        batterySearchStart = 0 
                        if inSafeZoneWaiting then
                            pcall(function() VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game) end)
                        end
                        inSafeZoneWaiting = false
                        cameraMovedInSafeZone = false
                        fPressedInSafeZone = false
                        
                        if isCarryingBattery then
                            _G.BBN_Status = "Carrying Battery"
                            -- Используем уже найденный bestFB вместо повторного сканирования всего Workspace
                            if not bestFB then
                                minDist = math.huge
                                if fbFolder then
                                    for _, fb in ipairs(fbFolder:GetChildren()) do scanFB(fb) end
                                end
                                for _, fb in ipairs(found.fuseboxes) do scanFB(fb) end
                            end

                            if bestFB then
                                local fbPart = bestFB:FindFirstChild("HumanoidRootPart") or bestFB:FindFirstChild("Position") or bestFB:FindFirstChildWhichIsA("BasePart", true)
                                if fbPart then
                                    local distToFB = (hrp.Position - fbPart.Position).Magnitude
                                    
                                    if distToFB > 8 and canTeleport(false) then
                                        -- СТРОГАЯ ПРОВЕРКА: Если мы прячемся ИЛИ маньяк рядом - НИКАКИХ телепортов!
                                        if isHidingUnderground or isFlying or killerDist < 60 then
                                            print("Cannot TP to FB: Killer too close or Hiding.")
                                            task.wait(0.5)
                                            continue 
                                        end

                                        print("Teleporting to nearest FuseBox Position: " .. bestFB.Name)
                                        local fbTpCF = getFuseboxTeleportCFrame(bestFB, fbPart)
                                        if fbTpCF then
                                            hrp.CFrame = fbTpCF
                                        end
                                        markTeleport()
                                        task.wait(0.1)
                                        distToFB = (hrp.Position - fbPart.Position).Magnitude
                                    end

                                    -- Если вставка не стартует, подходим ближе как на генераторах (мягкий дожим без спама)
                                    if distToFB > 4 and distToFB < 22 and tick() - lastFuseboxNudge > 1.25 then
                                        lastFuseboxNudge = tick()
                                        local posPart = bestFB:FindFirstChild("Position")
                                        if posPart and posPart:IsA("BasePart") then
                                            hrp.CFrame = posPart.CFrame
                                        else
                                            hrp.CFrame = CFrame.new(fbPart.Position + Vector3.new(0, 2.2, 0))
                                        end
                                        task.wait(0.08)
                                        distToFB = (hrp.Position - fbPart.Position).Magnitude
                                    end

                                    if distToFB < 8 then
                                        _G.BBN_Status = "Installing..."
                                        smoothAim(fbPart.Position, 0.3)
                                        local prompt = bestFB:FindFirstChildWhichIsA("ProximityPrompt", true)
                                        
                                        if getKillerDist() < 55 then continue end

                                        if prompt then fireproximityprompt(prompt) end
                                        task.wait(0.1)
                                        
                                        if distToFB < 5 and isCarryingBattery then
                                            _G.BBN_Status = "Charging..."
                                            local oldCamType = Workspace.CurrentCamera.CameraType
                                            local aimConn = RunService.RenderStepped:Connect(function()
                                                -- Не вызываем hasBattery() каждый кадр: это вызывало лаги из-за частого сканирования Descendants
                                                if autoGenEnabled and states["AUTO FARM"] then
                                                    Workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
                                                    Workspace.CurrentCamera.CFrame = CFrame.new(Workspace.CurrentCamera.CFrame.Position, fbPart.Position)
                                                end
                                            end)

                                            pcall(function() VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game) end)
                                            local holdStart = tick()
                                            while tick() - holdStart < 8 and lastCarryBatteryValue do
                                                if tick() - lastCarryBatteryCheck > 1.3 then
                                                    lastCarryBatteryCheck = tick()
                                                    lastCarryBatteryValue = hasBattery()
                                                end
                                                if getKillerDist() < 55 or not autoGenEnabled then
                                                    pcall(function() VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game) end)
                                                    break
                                                end
                                                task.wait(0.1)
                                            end
                                            pcall(function() VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game) end)
                                            aimConn:Disconnect()
                                            Workspace.CurrentCamera.CameraType = oldCamType
                                            
                                            if not lastCarryBatteryValue then
                                                markFuseBoxUsed(bestFB)
                                                print("Battery installed successfully in " .. bestFB.Name)
                                                bestFB = nil -- Сбрасываем цель после установки
                                                task.wait(0.5)
                                                -- СРАЗУ ПЕРЕХОДИМ К СЛЕДУЮЩЕЙ БАТАРЕЕ
                                                continue
                                            else
                                                -- Батарея всё ещё в руках: слегка сближаемся и пробуем снова на следующем тике
                                                if tick() - lastFuseboxNudge > 0.9 then
                                                    lastFuseboxNudge = tick()
                                                    local posPart = bestFB:FindFirstChild("Position")
                                                    if posPart and posPart:IsA("BasePart") then
                                                        hrp.CFrame = posPart.CFrame
                                                    else
                                                        hrp.CFrame = CFrame.new(fbPart.Position + Vector3.new(0, 2.0, 0))
                                                    end
                                                    task.wait(0.06)
                                                end
                                            end
                                        end
                                        continue
                                    end
                                end
                            else
                                _G.BBN_Status = "No Free FuseBox"
                                task.wait(1)
                                continue
                            end
                        else
                            -- Pick up battery
                            _G.BBN_Status = "Heading to Battery"
                            local bPart = battery:IsA("BasePart") and battery or battery:FindFirstChild("Position") or battery:FindFirstChildWhichIsA("BasePart", true)
                            if bPart then
                                local distToB = (hrp.Position - bPart.Position).Magnitude

                                -- Телепорт к батарее
                                if distToB > 10 and canTeleport(false) then
                                    print("Teleporting to battery...")
                                    hrp.CFrame = bPart.CFrame * CFrame.new(0, 2, 0)
                                    markTeleport()
                                    task.wait(0.2)
                                    distToB = (hrp.Position - bPart.Position).Magnitude
                                end

                                if distToB < 7 then
                                    _G.BBN_Status = "Picking up Battery"
                                    local oldCamType = Workspace.CurrentCamera.CameraType
                                    local aimConn = RunService.RenderStepped:Connect(function()
                                        -- Избегаем тяжелых hasBattery() в RenderStepped для снижения лагов
                                        if autoGenEnabled and states["AUTO FARM"] then
                                            Workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
                                            Workspace.CurrentCamera.CFrame = CFrame.new(Workspace.CurrentCamera.CFrame.Position, bPart.Position)
                                        end
                                    end)

                                    print("Holding F to pick up battery...")
                                    pcall(function() 
                                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
                                        local prompt = battery:FindFirstChildWhichIsA("ProximityPrompt", true)
                                        if prompt and fireproximityprompt then fireproximityprompt(prompt) end
                                    end)
                                    
                                    local holdStart = tick()
                                    local nextPickBatteryCheck = 0
                                    local nextPromptRetry = 0
                                    while tick() - holdStart < 8 do
                                        if tick() >= nextPickBatteryCheck then
                                            nextPickBatteryCheck = tick() + 0.3
                                            if hasBattery() then
                                                print("Battery detected in hand! Exiting pickup loop.")

                                                -- Ждем пока пройдут лаги после взятия батареи
                                                _G.BBN_Status = "We are waiting for the lags to pass😴"
                                                task.wait(2)

                                                break
                                            end
                                        end
                                        if getKillerDist() < 55 or not autoGenEnabled then break end
                                        
                                        _G.BBN_Status = "Picking up (" .. string.format("%.1f", 8 - (tick()-holdStart)) .. "s)"
                                        
                                        local prompt = battery:FindFirstChildWhichIsA("ProximityPrompt", true)
                                        if prompt and fireproximityprompt and tick() >= nextPromptRetry then
                                            nextPromptRetry = tick() + 0.32
                                            fireproximityprompt(prompt)
                                        end
                                        task.wait(0.11)
                                    end
                                    
                                    pcall(function() VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game) end)
                                    aimConn:Disconnect()
                                    Workspace.CurrentCamera.CameraType = oldCamType
                                end
                            end
                        end
                        continue 
                    end
                    
                    -- 2. BATTERY NOT AVAILABLE -> SEARCH FOR GENERATORS
                        local targetGen = nil
                        -- unfinishedGens уже заполнен выше
                        
                        if #unfinishedGens > 0 then
                            targetGen = unfinishedGens[1]
                        end

                        if targetGen then
                            if inSafeZoneWaiting then
                                pcall(function() VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game) end)
                            end
                            inSafeZoneWaiting = false -- Сброс режима Safe Zone
                            cameraMovedInSafeZone = false
                            fPressedInSafeZone = false

                            -- ПРОВЕРКА ПЕРЕД ВЫЛЕЗАНИЕМ: Если генератор уже починен - проверяем маньяка
                            if isGeneratorFinished(targetGen) then
                                print("⚠️ Target generator is already finished! Checking killer position...")

                                local mainPart = targetGen:IsA("BasePart") and targetGen or targetGen:FindFirstChild("Main") or targetGen:FindFirstChildWhichIsA("BasePart", true)
                                if mainPart then
                                    local killerPos = found.killers[1] and (found.killers[1]:IsA("Model") and found.killers[1].PrimaryPart or found.killers[1]:FindFirstChildWhichIsA("BasePart", true))

                                    if killerPos then
                                        local distKillerToGen = (killerPos.Position - mainPart.Position).Magnitude

                                        if distKillerToGen < 50 then
                                            print("❌ Killer is camping finished generator (dist: " .. math.floor(distKillerToGen) .. "m)! Skipping to next gen.")
                                            _G.BBN_Status = "Killer camping finished gen, skipping..."

                                            -- Помечаем как пропущенный и идем к следующему
                                            brokenGenerators[targetGen] = true
                                            currentRepairTargetGen = nil
                                            task.wait(1)
                                            continue
                                        end
                                    end

                                    -- Генератор починен и маньяка нет рядом - просто пропускаем
                                    print("✅ Generator finished and killer not camping. Skipping to next gen.")
                                    brokenGenerators[targetGen] = true
                                    currentRepairTargetGen = nil
                                    continue
                                end
                            end

                            _G.BBN_Status = "Heading to Gen"
                            
                            -- Если сменили генератор - сбрасываем индексы
                            if currentRepairTargetGen ~= targetGen then
                                currentRepairTargetGen = targetGen
                                currentRepairAttempts = 0
                                currentPromptIndex = 1
                                currentPointIndex = 1
                                print("Targeted new generator.")
                            end

                            local mainPart = targetGen:IsA("BasePart") and targetGen or targetGen:FindFirstChild("Main") or targetGen:FindFirstChildWhichIsA("BasePart", true)
                            if mainPart then
                                local prompts = {}
                                for _, v in ipairs(targetGen:GetDescendants()) do
                                    if v:IsA("ProximityPrompt") then table.insert(prompts, v) end
                                end
                                
                                -- Если промпты не найдены - пропускаем
                                if #prompts == 0 then
                                    print("No prompts on generator! Skipping.")
                                    brokenGenerators[targetGen] = true
                                    continue
                                end

                                -- Корректируем индекс промпта если он вышел за пределы
                                if currentPromptIndex > #prompts then
                                    print("All prompts tried! Skipping generator.")
                                    brokenGenerators[targetGen] = true
                                    currentRepairTargetGen = nil
                                    continue
                                end

                                local currentPrompt = prompts[currentPromptIndex]
                                local promptPart = currentPrompt.Parent:IsA("BasePart") and currentPrompt.Parent or mainPart
                                
                                -- Генерируем точки для ТЕКУЩЕГО промпта: центр + 4 стороны + углы
                                local points = {
                                    promptPart.CFrame * CFrame.new(0, 0, 3.5), -- Центр
                                    promptPart.CFrame * CFrame.new(3.5, 0, 0), -- Право
                                    promptPart.CFrame * CFrame.new(-3.5, 0, 0), -- Лево
                                    promptPart.CFrame * CFrame.new(0, 0, -3.5), -- Сзади
                                    promptPart.CFrame * CFrame.new(2.5, 0, 2.5), -- Угол 1
                                    promptPart.CFrame * CFrame.new(-2.5, 0, 2.5), -- Угол 2
                                    promptPart.CFrame * CFrame.new(2.5, 0, -2.5), -- Угол 3
                                    promptPart.CFrame * CFrame.new(-2.5, 0, -2.5), -- Угол 4
                                    promptPart.CFrame * CFrame.new(0, 1.5, 1.5) -- Сверху
                                }

                                local targetCFrame = points[currentPointIndex] or points[1]
                                local distToTarget = (hrp.Position - targetCFrame.Position).Magnitude

                                -- Если далеко от генератора - телепортируемся
                                if distToTarget > 7 and (hrp.Position - promptPart.Position).Magnitude > 7 then
                                    -- Проверка на маньяка
                                    if killerDist < 60 then
                                        print("Killer too close! Cannot teleport to generator.")
                                        task.wait(0.5)
                                        continue
                                    end

                                    if canTeleport(false) then
                                        print("Teleporting to generator (initial approach)...")
                                        hrp.CFrame = targetCFrame
                                        markTeleport()
                                        task.wait(0.2)

                                        -- Наводим камеру на промпт
                                        smoothAim(promptPart.Position, 0.3)
                                    else
                                        print("Teleport on cooldown, waiting...")
                                        task.wait(0.5)
                                        continue
                                    end
                                    continue
                                end

                                if (distToTarget < 7 or (hrp.Position - promptPart.Position).Magnitude < 7) then
                                    _G.BBN_Status = "Repairing..."
                                    
                                    -- Дополнительная проверка перед началом починки
                                    if killerDist < 60 then
                                        print("Killer came close! Stopping repair.")
                                        continue
                                    end

                                        -- Если мини-игра не открылась через 3 сек после ТП - пробуем следующую точку/промпт
                                    if not activeMiniEvent and tick() - lastTeleportTime > 3 then
                                        currentPointIndex = currentPointIndex + 1
                                        
                                        if currentPointIndex > #points then
                                            currentPointIndex = 1
                                            currentPromptIndex = currentPromptIndex + 1
                                        end
                                        
                                        if currentPromptIndex <= #prompts then
                                            local nextPrompt = prompts[currentPromptIndex]
                                            local nextPart = nextPrompt.Parent:IsA("BasePart") and nextPrompt.Parent or mainPart
                                            local nextPoint = points[currentPointIndex] or nextPart.CFrame * CFrame.new(0,0,3.5)

                                            -- Телепорт к следующей точке генератора
                                            if canTeleport(false) then
                                                print("Teleporting to generator point...")
                                                hrp.CFrame = nextPoint
                                                markTeleport()
                                                task.wait(0.2)

                                                -- Наводим камеру на промпт
                                                smoothAim(nextPart.Position, 0.3)
                                            else
                                                print("Teleport on cooldown, waiting...")
                                                task.wait(0.5)
                                            end
                                        end
                                        continue
                                    end

                                    -- Если мини-игра не открылась, пробуем нащупать кнопку
                                    if not activeMiniEvent then
                                        local oldCamType = Workspace.CurrentCamera.CameraType
                                        local aimConn = RunService.RenderStepped:Connect(function()
                                            if autoGenEnabled and not activeMiniEvent and currentRepairTargetGen == targetGen then
                                                Workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
                                                -- Динамическое наведение прямо на Промпт
                                                local targetLookAt = currentPrompt.Parent:IsA("BasePart") and currentPrompt.Parent.Position or promptPart.Position
                                                Workspace.CurrentCamera.CFrame = CFrame.new(Workspace.CurrentCamera.CFrame.Position, targetLookAt)
                                            end
                                        end)
                                        
                                        task.wait(0.1)
                                        if fireproximityprompt then fireproximityprompt(currentPrompt) end
                                        
                                        pcall(function() 
                                            print("Spamming F to start repair...")
                                            while not activeMiniEvent and autoGenEnabled and states["AUTO FARM"] do
                                                if getKillerDist() < 55 or isHidingUnderground or isFlying then 
                                                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                                    break 
                                                end
                                                
                                                _G.BBN_Status = "Starting Repair..."
                                                
                                                -- Спамим промпт и клавишу F
                                                if fireproximityprompt then fireproximityprompt(currentPrompt) end
                                                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
                                                
                                                task.wait(0.1)
                                                
                                                -- Если за 5 секунд на этой точке ничего не вышло - пробуем сменить точку (защита от застревания)
                                                if tick() - lastTeleportTime > 5 then
                                                    print("Timeout on this point, will try next.")
                                                    break
                                                end
                                            end
                                            
                                            if not activeMiniEvent then
                                                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                            end
                                        end)
                                        
                                        aimConn:Disconnect()
                                        Workspace.CurrentCamera.CameraType = oldCamType
                                    else
                                        -- Мини-игра уже открыта, сбрасываем попытки
                                        currentPointIndex = 1
                                        local oldCamType = Workspace.CurrentCamera.CameraType
                                        Workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
                                        Workspace.CurrentCamera.CFrame = CFrame.new(Workspace.CurrentCamera.CFrame.Position, promptPart.Position)
                                        
                                        if fireproximityprompt then fireproximityprompt(currentPrompt) end
                                        pcall(function() VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game) end)
                                        
                                        task.wait(0.2)
                                        Workspace.CurrentCamera.CameraType = oldCamType
                                    end
                                    task.wait(0.1)
                                    continue
                                else
                                    if canTeleport(false) then
                                        -- СТРОГАЯ ПРОВЕРКА: Если мы прячемся ИЛИ маньяк рядом - НИКАКИХ телепортов к генам!
                                        if isHidingUnderground or isFlying or killerDist < 60 then
                                            print("Cannot TP to Gen: Killer too close or Hiding.")
                                            task.wait(0.5)
                                            continue
                                        end

                                        local killerAtTarget = false
                                        local killerObj = nil
                                        local killerFolder = Workspace:FindFirstChild("PLAYERS") and Workspace.PLAYERS:FindFirstChild("KILLER")
                                        if killerFolder then
                                            killerObj = killerFolder:FindFirstChildWhichIsA("Model")
                                        end
                                        if killerObj and killerObj:FindFirstChild("HumanoidRootPart") then
                                            if (targetCFrame.Position - killerObj.HumanoidRootPart.Position).Magnitude <= 60 then
                                                killerAtTarget = true
                                            end
                                        end
                                        
                                        if killerAtTarget then
                                            print("Killer at target generator! Skipping TP.")
                                            _G.BBN_Status = "Killer at Gen"
                                            task.wait(1)
                                            continue
                                        end

                                        _G.BBN_Status = "TP to Gen"
                                        hrp.CFrame = targetCFrame
                                        markTeleport()
                                        task.wait(0.3)
                                        
                                        if getKillerDist() <= 55 then
                                            print("Killer detected at target! Hiding.")
                                            goUnderground()
                                            continue
                                        end
                                        
                                        smoothAim(promptPart.Position, 0.6)
                                        lastMiniGameTime = tick()
                                    end
                                end
                            end
                        else
                            -- 3. BATTERIES & GENS DONE -> SAFE ZONE
                            if batterySearchStart == 0 then batterySearchStart = tick() end
                            
                            if tick() - batterySearchStart < 5 then
                                _G.BBN_Status = "Searching Targets (" .. math.floor(5 - (tick()-batterySearchStart)) .. "s)"
                                task.wait(0.5)
                                continue
                            end

                            _G.BBN_Status = "Waiting in Safe"
                            local distToSafe = (hrp.Position - safeZoneFinalPos).Magnitude
                            
                            local safeCdReady = (tick() - lastSafeZoneTeleportAt) >= TELEPORT_COOLDOWN
                            if distToSafe > 10 and canTeleport(false) and safeCdReady then
                                print("No targets available. Teleporting to Safe Zone.")
                                pressKey(Enum.KeyCode.Space)
                                task.wait(0.05)
                                stopFly()
                                isHidingUnderground = false
                                hrp.CFrame = CFrame.new(safeZoneFinalPos)
                                markTeleport()
                                lastSafeZoneTeleportAt = tick()
                                
                                inSafeZoneWaiting = true
                                safeZoneRoutineStart = tick()
                                cameraMovedInSafeZone = false
                            end
                            
                            if distToSafe <= 10 then
                                if not inSafeZoneWaiting then
                                    inSafeZoneWaiting = true
                                    safeZoneRoutineStart = tick()
                                    cameraMovedInSafeZone = false
                                    fPressedInSafeZone = false
                                end
                                
                                if not cameraMovedInSafeZone then
                                    cameraMovedInSafeZone = true
                                    smoothAim(hrp.Position + Vector3.new(0, -10, 0), 0.5)
                                end

                                if cameraMovedInSafeZone and not fPressedInSafeZone and tick() - safeZoneRoutineStart >= 2 then
                                    fPressedInSafeZone = true
                                    pcall(function() VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game) end)
                                end
                            end
                            
                            local totalMins = getGameTime()
                            if totalMins >= 360 and totalMins < 1000 then
                                pcall(function() VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game) end)
                                isEscaping = true
                            end
                            task.wait(1)
                        end
                    end
            -- AUTO GEN (without AUTO FARM) - ONLY completes mini-game, NO teleport/aim
            elseif states["AUTO GEN"] and isSurvivor and hrp and hum and currentMap ~= "Waiting..." and not states["AUTO FARM"] then
                -- Killer protection + при прятках: телепорт в сейф / ротация выходов Pizzeria (см. cleanupHidingAndTeleportTo)
                local killerDist = getKillerDist()
                local foundNow = findObjects()
                if isMinionOnMe(foundNow.minions, char, hrp) then
                    _G.BBN_Status = "Minion on me! Shake"
                    if not isHidingUnderground and not isFlying then
                        goUnderground()
                    end
                    local function minionStillOnMe()
                        local c = player.Character
                        local r = c and c:FindFirstChild("HumanoidRootPart")
                        if not c or not r then return false end
                        local f = cachedObjects.data
                        if tick() - cachedObjects.lastUpdate > 0.6 then
                            f = findObjects()
                        end
                        return isMinionOnMe(f.minions, c, r)
                    end
                    shakeCameraRapid(5, minionStillOnMe)
                    task.wait(0.05)
                    continue
                end

                -- Instant reaction if killer is within 55m
                if killerDist < 55 and not justReturnedFromUnderground then
                    if not isHidingUnderground and not isFlying then
                        _G.BBN_Status = "Hiding"
                        goUnderground()
                    end
                end

                -- Return to surface when killer is far (>=100m for Forest, >=60m for others)
                local currentMap = detectMap()
                local returnDist = (currentMap == "Forest") and 100 or 60
                if killerDist >= returnDist and killerDist ~= 1000 then
                    if isHidingUnderground or isFlying then
                        print("Killer far enough (" .. math.floor(killerDist) .. "m). Ascending.")
                        _G.BBN_Status = "Exiting"
                        forceReturnFromHide(currentMap)
                    end
                end

                if isHidingUnderground or isFlying then
                    local mapGn = detectMap()
                    local targetReached = false
                    if mapGn == "Forest" then
                        if hrp.Position.Y >= 35 then targetReached = true end
                    else
                        if hrp.Position.Y <= (originalPosBeforeHide and originalPosBeforeHide.Y - 4 or -20) or hrp.Position.Y <= MIN_DEPTH_Y + 5 then targetReached = true end
                    end

                    if not targetReached then
                        _G.BBN_Status = "Moving to Hideout"
                    else
                        _G.BBN_Status = "Hidden"
                    end
                    task.wait(0.1)
                    continue
                end

                -- Mini-game check
                local pGui = player:FindFirstChild("PlayerGui")
                local activeMiniEvent = nil
                if pGui then
                    for _, g in ipairs(pGui:GetChildren()) do
                        if g:IsA("ScreenGui") and (g.Name:find("Minigame") or g.Name:find("Generator") or g:FindFirstChild("MainFrame") or g:FindFirstChild("Container")) then
                            local main = g:FindFirstChild("MainFrame") or g:FindFirstChild("Container")
                            if main and (main.Visible or (main:IsA("CanvasGroup") and main.GroupTransparency < 1)) then
                                activeMiniEvent = g:FindFirstChild("Event", true) or main:FindFirstChild("Event", true)
                                if activeMiniEvent then break end
                            end
                        end
                    end
                end

                if activeMiniEvent then
                    _G.BBN_Status = "Completing Gen"
                    if tick() - lastRepairTime >= repairCooldown then
                        print("AUTO GEN: Finishing mini-game...")
                        activeMiniEvent:FireServer({["Wires"]=true,["Switches"]=true,["Lever"]=true,["Type"]="Finish"}) 
                        lastRepairTime = tick()
                        repairCooldown = math.random(5, 7)
                        
                        -- Проверка не закончился ли генератор после нашего действия
                        task.spawn(function()
                            task.wait(1)
                            local found = findObjects()
                            local hrpPos = hrp.Position
                            for _, gen in ipairs(found.generators) do
                                local genPart = gen:IsA("BasePart") and gen or gen:FindFirstChildWhichIsA("BasePart", true)
                                if genPart and (hrpPos - genPart.Position).Magnitude < 15 then
                                    if isGeneratorFinished(gen) then
                                        _G.BBN_GensRepaired = (_G.BBN_GensRepaired or 0) + 1
                                        print("AUTO GEN: Generator finished by me!")
                                        break
                                    end
                                end
                            end
                        end)
                    end
                else
                    _G.BBN_Status = "Idle"
                end
            end
            task.wait(0.1) -- Faster loop for instant reaction (55m check)
        end 
    end)
end

