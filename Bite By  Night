        pingLabel.Text = "Ping: 0ms"
        pingLabel.TextColor3 = Color3.new(0.8, 0.8, 0.8)
        pingLabel.Font = Enum.Font.Gotham
        pingLabel.TextSize = 10
        pingLabel.TextXAlignment = Enum.TextXAlignment.Left
        pingLabel.BackgroundTransparency = 1
        pingLabel.ZIndex = 9

        local batGenCountLabel = Instance.new("TextLabel", logsFrame)
        batGenCountLabel.Size = UDim2.new(0.5, 0, 0, 15)
        batGenCountLabel.Position = UDim2.new(0.5, 0, 0, 75)
        batGenCountLabel.Text = "Bat: 0 | Gen: 0"
        batGenCountLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        batGenCountLabel.Font = Enum.Font.Gotham
        batGenCountLabel.TextSize = 10
        batGenCountLabel.TextXAlignment = Enum.TextXAlignment.Right
        batGenCountLabel.BackgroundTransparency = 1
        batGenCountLabel.ZIndex = 9

        task.spawn(function()
            local lastTimeValue = 0
            local dotIndex = 0
            local lastWorkspaceTimerSearch = 0
            local lastUIUpdate = 0
            while logsFrame.Parent and _G.BBN_Running do
                if tick() - lastUIUpdate < 0.5 then
                    task.wait(0.1)
                    continue
                end
                lastUIUpdate = tick()

                -- Принудительное обновление дистанции в UI потоке
                getKillerDist()
                
                -- Обновление счетчиков объектов
                local currentFound = cachedObjects.data
                if tick() - cachedObjects.lastUpdate > 4 then
                    currentFound = findObjects()
                end
                local bCount = #currentFound.batteries
                local gCount = 0
                for _, g in ipairs(currentFound.generators) do if not isGeneratorFinished(g) then gCount = gCount + 1 end end
                batGenCountLabel.Text = string.format("Bat: %d | Gen: %d", bCount, gCount)
                
                -- Update ON/OFF
                local isFarmOn = states["AUTO FARM"]
                farmStateLabel.Text = "Auto Farm: " .. (isFarmOn and "ON" or "OFF")
                farmStateLabel.TextColor3 = isFarmOn and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 100, 100)

                -- Update stats
                gensLabel.Text = "Gens repaired: " .. (_G.BBN_GensRepaired or 0)
                
                local elapsed = tick() - lastTeleportTime
                local remaining = math.max(0, math.ceil(nextTeleportCooldown - elapsed))
                if remaining > 0 then
                    cooldownLabel.Text = string.format("Teleport Cooldown: %d s", remaining)
                    cooldownLabel.TextColor3 = Color3.fromRGB(255, 150, 100)
                else
                    cooldownLabel.Text = "Teleport Cooldown: Ready"
                    cooldownLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                end

                local kDist = lastKillerDist or 1000
                distLabel.Text = kDist < 1000 and string.format("Dist: %d m", math.floor(kDist)) or "Dist: --"
                distLabel.TextColor3 = kDist < 55 and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(255, 100, 100)

                -- Пинг: используем комбинацию для максимальной точности
                local ping = 0
                pcall(function()
                    -- Этот метод дает наиболее близкий результат к Shift+F3 (Network Latency)
                    ping = math.floor(game:GetService("Stats").Network:GetRealTimeLatency() * 1000)
                end)
                
                -- Если результат все еще низкий, пробуем альтернативный множитель или Stats
                if ping < 10 then 
                    pcall(function() ping = math.floor(Stats.PerformanceStats.Ping:GetValue()) end)
                end
                
                -- Финальная коррекция: Shift+F3 часто показывает Round Trip Time, который может быть чуть выше
                if ping > 0 then
                    pingLabel.Text = "Ping: " .. (ping + 5) .. "ms" -- Небольшое смещение для визуального соответствия
                else
                    pingLabel.Text = "Ping: " .. math.floor(player:GetNetworkPing() * 1000) .. "ms"
                end
                
                local currentMap = detectMap()
                local gameFolder = Workspace:FindFirstChild("GAME")
                local timerValue = gameFolder and (gameFolder:FindFirstChild("TIMER") or gameFolder:FindFirstChild("Time") or gameFolder:FindFirstChild("Timer"))
                
                -- Если в GAME не нашли, ищем в ReplicatedStorage (стандарт для Bite By Night)
                if not timerValue then
                    local rs = game:GetService("ReplicatedStorage")
                    timerValue = rs:FindFirstChild("TIMER") or rs:FindFirstChild("Timer") or rs:FindFirstChild("Time") or rs:FindFirstChild("GameTime")
                end
                
                -- Проверка Lighting (стандарт Roblox)
                local lighting = game:GetService("Lighting")
                local timeStr = lighting.TimeOfDay
                
                -- Редкий тяжёлый поиск по Workspace (раньше каждые 0.35 с давал лаги)
                if not timerValue and tick() - lastWorkspaceTimerSearch > 20 then
                    lastWorkspaceTimerSearch = tick()
                    for _, v in ipairs(Workspace:GetDescendants()) do
                        if (v.Name == "TIMER" or v.Name == "Timer" or v.Name == "Time" or v.Name == "GameTime") and (v:IsA("NumberValue") or v:IsA("IntValue") or v:IsA("StringValue")) then
                            timerValue = v
                            break
                        end
                    end
                end
                
                -- Анимация точек змейкой
                dotIndex = (dotIndex % 3) + 1
                local dots = (dotIndex == 1 and ".  " or (dotIndex == 2 and ".. " or "..."))
                
                local char = player.Character
                local isKiller = false
                local isInLobby = false
                
                -- Прямая проверка иерархии: Workspace -> PLAYERS -> (Alive / Killer / Lobby)
                local playersFolder = Workspace:FindFirstChild("PLAYERS")
                if playersFolder and char then
                    local parent = char.Parent
                    if parent then
                        local parentName = parent.Name:upper()
                        if parentName == "LOBBY" then
                            isInLobby = true
                        elseif parentName == "KILLER" then
                            isKiller = true
                        end
                    end
                end
                
                -- Резервный метод проверки если папка PLAYERS не найдена
                if not isInLobby and not isKiller and char then
                    if char:GetAttribute("Role") == "Killer" then
                        isKiller = true
                    elseif currentMap == "Waiting..." then
                        isInLobby = true
                    end
                end

                if timerValue or timeStr then
                    local totalSeconds = 0
                    if timerValue then
                        pcall(function()
                            totalSeconds = tonumber(timerValue.Value) or 0
                        end)
                    else
                        -- Парсим TimeOfDay (HH:MM:SS) в секунды для совместимости
                        local h, m, s = timeStr:match("(%d+):(%d+):(%d+)")
                        if h and m and s then
                            totalSeconds = (tonumber(h) * 60) + tonumber(m) -- Для игры важны часы и минуты
                        end
                    end
                    
                    if isInLobby then
                        statusLabel.Text = "Status: Waiting"
                        -- Если в лобби, показываем реальное время игры или системное
                        timeLabel.Text = "Time: " .. (timeStr and timeStr:sub(1,5) or "Lobby")
                    elseif isKiller then
                        statusLabel.Text = "Status: Playing"
                        local gameHour = math.floor(totalSeconds / 60)
                        local gameMinute = totalSeconds % 60
                        if gameHour >= 24 then gameHour = gameHour % 24 end
                        
                        -- Формат 12-часовой с AM/PM
                        local displayHour = gameHour % 12
                        if displayHour == 0 then displayHour = 12 end
                        local ampm = gameHour >= 12 and "PM" or "AM"
                        
                        timeLabel.Text = string.format("Time: %02d:%02d %s", displayHour, gameMinute, ampm)
                    elseif states["AUTO FARM"] then
                        statusLabel.Text = "Status: " .. (_G.BBN_Status or "Active")
                        local gameHour = math.floor(totalSeconds / 60)
                        local gameMinute = totalSeconds % 60
                        if gameHour >= 24 then gameHour = gameHour % 24 end
                        
                        -- Формат 12-часовой с AM/PM
                        local displayHour = gameHour % 12
                        if displayHour == 0 then displayHour = 12 end
                        local ampm = gameHour >= 12 and "PM" or "AM"
                        
                        timeLabel.Text = string.format("Time: %02d:%02d %s", displayHour, gameMinute, ampm)
                    else
                        statusLabel.Text = "Status: Waiting to start"
                        if totalSeconds > 0 then
                            local gameHour = math.floor(totalSeconds / 60)
                            local gameMinute = totalSeconds % 60
                            if gameHour >= 24 then gameHour = gameHour % 24 end
                            local displayHour = gameHour % 12
                            if displayHour == 0 then displayHour = 12 end
                            local ampm = gameHour >= 12 and "PM" or "AM"
                            timeLabel.Text = string.format("Time: %02d:%02d %s", displayHour, gameMinute, ampm)
                        else
                            timeLabel.Text = "Time: Waiting" .. dots
                        end
                    end
                    lastTimeValue = totalSeconds
                else
                    timeLabel.Text = "Time: Waiting" .. dots
                end

                -- Дистанция до маньяка больше не обновляется здесь, только в боковом меню
                
                if isInLobby then
                    roleLabel.Text = "Role: Lobby"
                else
                    roleLabel.Text = "Role: " .. (isKiller and "Killer" or "Survivor")
                end
                
                task.wait(0.35) -- Снижаем нагрузку UI-цикла, чтобы убрать лаги после батареи
            end
        end)
    end
end

