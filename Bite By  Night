local function goUnderground()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp and not isHidingUnderground and not isFlying then
        -- Определяем текущую карту
        local currentMap = detectMap()

        -- Если мы на поверхности (Y > -10 и < 50) или позиция еще не сохранена - сохраняем
        -- Ограничение < 50 нужно, чтобы не сохранить позицию в небе на карте Forest
        if not originalPosBeforeHide or (hrp.Position.Y > -10 and hrp.Position.Y < 50) or currentMap == "Warehouse" then
            originalPosBeforeHide = hrp.Position
            print("Saving surface position: " .. tostring(originalPosBeforeHide))
        end
        
        isHidingUnderground = true 
        _G.BBN_Status = "Hiding"
        hideStartTime = tick()

        -- ВЫХОДИМ ИЗ ГЕНЕРАТОРА ПЕРЕД СКРЫТИЕМ
        pcall(function()
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
        end)

        -- Определяем текущую карту
        local currentMap = detectMap()

        -- Для Forest летим вверх до Y=100 (как раньше)
        if currentMap == "Forest" then
            print("Forest map - flying UP to y100")

            -- Отключаем коллизию для всех частей персонажа
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end

            -- Летим вверх до y100
            startFlyUp(100)

            -- Поворачиваем камеру вверх
            smoothAim(hrp.Position + Vector3.new(0, 10, 0), 0.4)
        else
            -- Для других карт - делаем объекты прозрачными и летим вниз
            makeObjectsTransparent()

            -- Отключаем коллизию для всех частей персонажа
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end

            -- Летим глубоко вниз (на MIN_DEPTH_Y)
            local targetDepth = MIN_DEPTH_Y

            -- Запускаем полёт вниз
            startFlyDown(targetDepth)

            print("Flying deep underground to Y: " .. targetDepth)

            -- Поворачиваем камеру вниз
            smoothAim(hrp.Position + Vector3.new(0, -10, 0), 0.4)
        end
    end
end

local function returnToSurface()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp and originalPosBeforeHide then
        print("Returning to surface...")
        _G.BBN_Status = "Exiting"

        -- Снимаем якорь и останавливаем полёт ПЕРЕД ТЕЛЕПОРТОМ
        isHidingUnderground = false
        isFlying = false
        flyDirection = nil
        
        if flyConnection then
            flyConnection:Disconnect()
            flyConnection = nil
        end
        
        -- Якорим перед ТП, чтобы не провалиться в момент перемещения
        hrp.Anchored = true
        hrp.Velocity = Vector3.new(0, 0, 0)
        
        -- Телепортируем на исходную позицию
        hrp.CFrame = CFrame.new(originalPosBeforeHide + Vector3.new(0, 2.5, 0))
        
        -- СБРОС КАМЕРЫ: Возвращаем управление игроку
        local cam = Workspace.CurrentCamera
        cam.CameraType = Enum.CameraType.Custom
        if currentTween then currentTween:Cancel() end
        
        -- СНАЧАЛА ВОССТАНАВЛИВАЕМ КОЛЛИЗИЮ И ПРОЗРАЧНОСТЬ
        restoreObjectsTransparency()
        toggleNoclip(false)
        
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end

        task.wait(0.3) -- Даем время движку Roblox просчитать пол под нами
        
        -- ТОЛЬКО ПОТОМ СНИМАЕМ ЯКОРЬ
        hrp.Anchored = false
        hrp.Velocity = Vector3.new(0, 0, 0)
        
        -- Сбрасываем состояние и ставим кулдаун
        originalPosBeforeHide = nil
        justReturnedFromUnderground = true
        
        -- Дожимаем F после возврата, если мы на генераторе
        pcall(function()
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
        end)

        task.spawn(function()
            task.wait(RETURN_COOLDOWN)
            justReturnedFromUnderground = false
            _G.BBN_Status = "Idle"
        end)

        print("Returned to surface!")
    end
end

