            spiritSphere = Instance.new("Part", Workspace)
            spiritSphere.Shape = Enum.PartType.Ball
            spiritSphere.Size = Vector3.new(0.5,0.5,0.5)
            spiritSphere.Color = Color3.fromRGB(0, 150, 255)
            spiritSphere.Material = Enum.Material.Neon
            spiritSphere.Anchored, spiritSphere.CanCollide, spiritSphere.Transparency = true, false, 0.5
            spiritSphere.CFrame = player.Character.HumanoidRootPart.CFrame
            spiritSphere.Name = "BBN_Spirit"

            local fire = Instance.new("Fire", spiritSphere)
            fire.Color, fire.SecondaryColor, fire.Heat, fire.Size = Color3.fromRGB(0, 100, 255), Color3.fromRGB(0, 255, 255), 5, 2
            
            player.Character.HumanoidRootPart.Anchored = true
            Workspace.CurrentCamera.CameraSubject = spiritSphere
            spiritConn = RunService.RenderStepped:Connect(function(dt)
                if not spiritEnabled or not spiritSphere then return end
                local moveDir = Vector3.new(0,0,0)
                local camCF = Workspace.CurrentCamera.CFrame
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camCF.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camCF.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camCF.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camCF.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0, 1, 0) end
                local speed = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 80 or 35
                spiritSphere.CFrame = spiritSphere.CFrame + (moveDir * speed * dt)
                fire.Size = moveDir.Magnitude > 0 and 3 or 2
            end)
            while spiritEnabled and _G.BBN_Running do task.wait(0.1) end
            if spiritConn then spiritConn:Disconnect() end
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                player.Character.HumanoidRootPart.Anchored = false
                player.Character.HumanoidRootPart.CFrame = spiritSphere.CFrame
                Workspace.CurrentCamera.CameraSubject = player.Character.Humanoid
            end
            if spiritSphere then spiritSphere:Destroy() end
        end)
    end
end

